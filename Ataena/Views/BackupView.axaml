<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ataena.ViewModels"
             xmlns:models="using:Ataena.Models"
             xmlns:converters="using:Ataena.Converters"
             x:Class="Ataena.Views.BackupView"
             x:DataType="vm:BackupViewModel">

  <Grid RowDefinitions="Auto,*" Margin="30">

    <!-- Cabecera -->
    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <TextBlock Text="💾 Backup y Restauración"
                 FontSize="28"
                 FontWeight="Bold"/>
      <TextBlock Text="Gestiona tus copias de seguridad en la nube"
                 Opacity="0.6"
                 Margin="0,4,0,0"/>
    </StackPanel>

    <!-- Contenido -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="24">

        <!-- Crear Backup -->
        <Border Background="#111827"
                CornerRadius="12"
                Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="📦 Crear Backup"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <Button Content="🔄 Crear Backup Ahora"
                    Classes="btn-primary"
                    Command="{Binding CrearBackupCommand}"
                    HorizontalAlignment="Left"
                    MinWidth="200"
                    Height="42"
                    Padding="16,0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
              <TextBlock Text="Último backup:"
                         Opacity="0.7"
                         VerticalAlignment="Center"/>
              <TextBlock Text="{Binding UltimoBackup.FechaCreacion, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         IsVisible="{Binding UltimoBackup, Converter={StaticResource IsNotNullConverter}}"/>
              <TextBlock Text="Ninguno"
                         Opacity="0.5"
                         IsVisible="{Binding UltimoBackup, Converter={StaticResource IsNullConverter}}"/>
            </StackPanel>

            <TextBlock Text="{Binding MensajeEstado}"
                       FontSize="12"
                       Opacity="0.8"
                       Margin="0,4,0,0"
                       IsVisible="{Binding MensajeEstado, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <ProgressBar Value="{Binding Progreso}"
                         Maximum="100"
                         IsVisible="{Binding Cargando}"
                         Height="6"
                         Margin="0,8,0,0"/>
          </StackPanel>
        </Border>

        <!-- Configuración de Nube -->
        <Border Background="#111827"
                CornerRadius="12"
                Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="☁️ Configuración de Nube"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <StackPanel>
              <TextBlock Text="Servicio de nube:"
                         Opacity="0.7"
                         Margin="0,0,0,5"/>
              <ComboBox ItemsSource="{Binding ServiciosNube}"
                        SelectedItem="{Binding ServicioNubeSeleccionado}"
                        Width="300"
                        HorizontalAlignment="Left">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding Nombre}"/>
                      <TextBlock Text="{Binding MensajeEstado}"
                                 FontSize="11"
                                 Opacity="0.6"/>
                    </StackPanel>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>

            <StackPanel Margin="0,8,0,0">
              <TextBlock Text="Carpeta de backups:"
                         Opacity="0.7"
                         Margin="0,0,0,5"/>
              <TextBox Text="{Binding ServicioNubeSeleccionado.RutaCarpeta}"
                       IsReadOnly="True"
                       Width="500"
                       HorizontalAlignment="Left"/>
            </StackPanel>

            <CheckBox Content="Copiar automáticamente a la nube después de cada backup"
                      IsChecked="{Binding CopiarAutomaticamenteNube}"
                      Margin="0,12,0,0"/>

            <Button Content="💾 Guardar Configuración"
                    Classes="btn-secondary"
                    Command="{Binding GuardarConfiguracionCommand}"
                    IsEnabled="{Binding !Cargando}"
                    HorizontalAlignment="Left"
                    MinWidth="200"
                    Height="36"
                    Padding="16,0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Margin="0,12,0,0"/>
          </StackPanel>
        </Border>

        <!-- Backup Automático -->
        <Border Background="#111827"
                CornerRadius="12"
                Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="⚙️ Backup Automático"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <CheckBox Content="Activar backup automático"
                      IsChecked="{Binding BackupAutomaticoActivo}"/>

            <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="20" Margin="0,12,0,0"
                  IsVisible="{Binding BackupAutomaticoActivo}">
              <StackPanel Grid.Column="0">
                <TextBlock Text="Frecuencia:"
                           Opacity="0.7"
                           Margin="0,0,0,5"/>
                <ComboBox SelectedIndex="{Binding BackupFrecuencia}"
                          Width="150"
                          HorizontalAlignment="Left">
                  <ComboBoxItem Content="Diario"/>
                  <ComboBoxItem Content="Semanal"/>
                  <ComboBoxItem Content="Mensual"/>
                </ComboBox>
              </StackPanel>

              <StackPanel Grid.Column="1">
                <TextBlock Text="Hora:"
                           Opacity="0.7"
                           Margin="0,0,0,5"/>
                <NumericUpDown Value="{Binding BackupHora}"
                               Minimum="0"
                               Maximum="1439"
                               Width="120"
                               HorizontalAlignment="Left"
                               FormatString="00:00"/>
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="Mantener últimos:"
                           Opacity="0.7"
                           Margin="0,0,0,5"/>
                <NumericUpDown Value="{Binding BackupMantenerUltimos}"
                               Minimum="1"
                               Maximum="100"
                               Width="100"
                               HorizontalAlignment="Left"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Historial de Backups -->
        <Border Background="#111827"
                CornerRadius="12"
                Padding="20">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
              <TextBlock Text="📋 Historial de Backups"
                         FontSize="18"
                         FontWeight="Bold"
                         Grid.Column="0"/>
              <Button Content="🔄 Actualizar"
                      Classes="btn-secondary"
                      Command="{Binding ActualizarListaBackupsCommand}"
                      IsEnabled="{Binding !Cargando}"
                      Grid.Column="1"
                      MinWidth="100"
                      Height="32"
                      Padding="12,0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding Backups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="#1a1a2e"
                          CornerRadius="8"
                          Padding="16"
                          Margin="0,0,0,12">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding NombreArchivo}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Spacing="12" Opacity="0.7">
                          <TextBlock Text="{Binding FechaCreacion, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"/>
                          <TextBlock Text="{Binding TamañoFormateado}"/>
                          <TextBlock Text="✅ Sincronizado"
                                     IsVisible="{Binding Sincronizado}"/>
                        </StackPanel>
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="👁️ Info"
                              Classes="btn-secondary"
                              Command="{Binding $parent[UserControl].((vm:BackupViewModel)DataContext).VerInfoBackupCommand}"
                              CommandParameter="{Binding}"
                              MinWidth="80"
                              Height="32"
                              Padding="12,0"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"/>
                      <Button Grid.Column="2"
                              Content="📥 Restaurar"
                              Classes="btn-primary"
                              Command="{Binding $parent[UserControl].((vm:BackupViewModel)DataContext).RestaurarBackupCommand}"
                              CommandParameter="{Binding}"
                              MinWidth="100"
                              Height="32"
                              Padding="12,0"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"/>
                      <Button Grid.Column="3"
                              Content="🗑️"
                              Classes="btn-secondary"
                              Command="{Binding $parent[UserControl].((vm:BackupViewModel)DataContext).EliminarBackupCommand}"
                              CommandParameter="{Binding}"
                              Width="32"
                              Height="32"
                              Padding="0"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="No hay backups disponibles"
                       Opacity="0.5"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"
                       IsVisible="{Binding Backups.Count, Converter={StaticResource EqualConverter}, ConverterParameter=0}"/>
          </StackPanel>
        </Border>

        <!-- Restaurar desde archivo -->
        <Border Background="#111827"
                CornerRadius="12"
                Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="⚠️ Restaurar desde archivo"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Para restaurar en un PC nuevo:"
                       Opacity="0.7"
                       Margin="0,0,0,8"/>

            <StackPanel Spacing="4" Margin="0,0,0,12">
              <TextBlock Text="1. Instala Ataena" Opacity="0.8"/>
              <TextBlock Text="2. Abre esta sección" Opacity="0.8"/>
              <TextBlock Text="3. Selecciona un backup de la lista arriba" Opacity="0.8"/>
              <TextBlock Text="4. Click en 'Restaurar'" Opacity="0.8"/>
            </StackPanel>

            <Button Content="📂 Seleccionar archivo ZIP..."
                    Classes="btn-secondary"
                    Command="{Binding RestaurarDesdeArchivoCommand}"
                    IsEnabled="{Binding !Cargando}"
                    HorizontalAlignment="Left"
                    MinWidth="200"
                    Height="36"
                    Padding="16,0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Mensajes de error -->
        <Border Background="#3d2a2a"
                CornerRadius="8"
                Padding="12"
                IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <TextBlock Text="{Binding MensajeError}"
                     Foreground="#ff6b6b"
                     TextWrapping="Wrap"/>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </Grid>

</UserControl>

