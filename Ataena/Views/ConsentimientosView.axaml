<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ataena.ViewModels"
             xmlns:models="using:Ataena.Models"
             xmlns:views="using:Ataena.Views"
             x:Class="Ataena.Views.ConsentimientosView"
             x:DataType="vm:ConsentimientosViewModel">

  <UserControl.Styles>
    <Style Selector="Border.consentimiento-card">
      <Setter Property="Background" Value="#1a1a2e"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="14,12"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#2a2a3e"/>
    </Style>
    <Style Selector="Border.consentimiento-card:pointerover">
      <Setter Property="Background" Value="#22223a"/>
      <Setter Property="BorderBrush" Value="#4c3d6e"/>
    </Style>
    <Style Selector="Border.chip">
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="7,3"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="30">

    <!-- Cabecera -->
    <StackPanel Grid.Row="0">
      <TextBlock Text="📝 Consentimientos"
                 FontSize="28"
                 FontWeight="Bold"/>
      <TextBlock Opacity="0.6" Margin="0,5,0,0">
        <Run Text="Total: "/>
        <Run Text="{Binding TotalConsentimientos}"/>
        <Run Text=" consentimientos firmados"/>
      </TextBlock>
    </StackPanel>

    <!-- Contenido principal -->
    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,20,0,0">

      <!-- Búsqueda y filtros -->
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
        <TextBox Grid.Column="0"
                 Text="{Binding TextoBusqueda}"
                 Watermark="🔍 Buscar por nombre, apellidos, DNI o teléfono..."
                 Margin="0,0,10,0"/>
        <ComboBox Grid.Column="1"
                  SelectedItem="{Binding TipoFiltro}"
                  PlaceholderText="Todos los tipos"
                  MinWidth="180"
                  Margin="0,0,10,0">
          <ComboBox.Items>
            <x:Null/>
            <x:Static Member="models:TipoConsentimiento.RGPD"/>
            <x:Static Member="models:TipoConsentimiento.RGPD_Menor"/>
            <x:Static Member="models:TipoConsentimiento.Imagenes"/>
            <x:Static Member="models:TipoConsentimiento.Imagenes_Menor"/>
            <x:Static Member="models:TipoConsentimiento.Trabajo"/>
            <x:Static Member="models:TipoConsentimiento.Trabajo_Menor"/>
          </ComboBox.Items>
        </ComboBox>
        <Button Grid.Column="2"
                Content="Limpiar"
                Classes="btn-secondary"
                Command="{Binding LimpiarFiltrosCommand}"/>
      </Grid>

      <!-- Lista -->
      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Consentimientos}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:Consentimiento">
              <Border Classes="consentimiento-card">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                  <!-- Barra tipo -->
                  <Border Grid.Column="0"
                          Width="4"
                          CornerRadius="2"
                          Background="#6366f1"
                          Margin="0,2,10,2"
                          VerticalAlignment="Stretch"
                          MinHeight="48"/>

                  <!-- Info -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="{Binding NombreTipo}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#f1f5f9"/>
                    <TextBlock Text="{Binding Cliente.NombreCompleto}"
                               FontSize="14"
                               Foreground="#cbd5e1"/>
                    <StackPanel Orientation="Horizontal" Spacing="14">
                      <TextBlock FontSize="12" Foreground="#94a3b8"
                                 IsVisible="{Binding Cliente.Telefono, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <Run Text="📞 "/>
                        <Run Text="{Binding Cliente.Telefono}"/>
                      </TextBlock>
                      <TextBlock FontSize="12" Foreground="#94a3b8"
                                 IsVisible="{Binding Cliente.Dni, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <Run Text="🪪 "/>
                        <Run Text="{Binding Cliente.Dni}"/>
                      </TextBlock>
                    </StackPanel>
                    <TextBlock FontSize="12"
                               Foreground="#64748b"
                               IsVisible="{Binding Trabajo}"
                               TextTrimming="CharacterEllipsis">
                      <Run Text="Trabajo: "/>
                      <Run Text="{Binding Trabajo.Descripcion}"/>
                    </TextBlock>
                  </StackPanel>

                  <!-- Acciones -->
                  <StackPanel Grid.Column="2"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Right"
                              Spacing="8">
                    <TextBlock Text="{Binding FechaFirma, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                               FontSize="12"
                               Foreground="#64748b"
                               HorizontalAlignment="Right"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Button Classes="btn-secondary"
                              MinWidth="64"
                              Height="34"
                              Padding="8,0"
                              ToolTip.Tip="Abrir PDF"
                              Command="{Binding $parent[UserControl].DataContext.AbrirConsentimientoCommand}"
                              CommandParameter="{Binding}">
                        <TextBlock Text="Ver" FontSize="12"/>
                      </Button>
                      <Button Classes="btn-secondary"
                              MinWidth="76"
                              Height="34"
                              Padding="8,0"
                              ToolTip.Tip="Firmar de nuevo"
                              Command="{Binding $parent[UserControl].DataContext.RenovarConsentimientoCommand}"
                              CommandParameter="{Binding}">
                        <TextBlock Text="Renovar" FontSize="12"/>
                      </Button>
                      <Button Classes="btn-danger"
                              MinWidth="68"
                              Height="34"
                              Padding="8,0"
                              ToolTip.Tip="Eliminar consentimiento"
                              Command="{Binding $parent[UserControl].DataContext.EliminarConsentimientoCommand}"
                              CommandParameter="{Binding}">
                        <TextBlock Text="Borrar" FontSize="12"/>
                      </Button>
                    </StackPanel>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

    <views:ConsentimientoFirmaView Grid.RowSpan="3" DataContext="{Binding ConsentimientoFirmaVM}"/>

    <!-- Mensaje de error -->
    <Border Grid.Row="2"
            IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="#3d2a2a"
            CornerRadius="6"
            Padding="10"
            Margin="0,10,0,0">
      <TextBlock Text="{Binding MensajeError}" Foreground="#ef5350"/>
    </Border>

  </Grid>
</UserControl>
