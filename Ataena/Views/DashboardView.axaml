<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ataena.ViewModels"
             xmlns:models="using:Ataena.Models"
             x:Class="Ataena.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             Loaded="OnLoaded">

    <UserControl.Styles>
        <!-- Estilo para tarjetas de estadísticas -->
        <Style Selector="Border.stat-card">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="MinWidth" Value="140"/>
        </Style>
        
        <!-- Estilo para tarjetas de contenido -->
        <Style Selector="Border.content-card">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        
        <!-- Estilo para items de cita -->
        <Style Selector="Border.cita-item">
            <Setter Property="Background" Value="#2a2a3e"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <!-- Estilo para alertas -->
        <Style Selector="Border.alerta-item">
            <Setter Property="Background" Value="#3d2a2a"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        
        <!-- Botón de acción rápida -->
        <Style Selector="Button.quick-action">
            <Setter Property="Background" Value="#2a2a3e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.quick-action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3a3a4e"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="30">
            
            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- FILA 0: CABECERA                                            -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,30">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Saludo}" 
                               FontSize="32" 
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding NombreEstudio}" 
                               FontSize="16" 
                               Opacity="0.6"
                               Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding FechaHoy}" 
                               FontSize="16"
                               Opacity="0.8"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- FILA 1: ACCIONES RÁPIDAS                                    -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="12"
                        Margin="0,0,0,25">
                <Button Classes="quick-action"
                        Content="➕ Nuevo cliente"
                        Command="{Binding NuevoClienteRapidoCommand}"
                        MinWidth="170"/>
                <Button Classes="quick-action"
                        Content="➕ Nueva cita"
                        Command="{Binding NuevaCitaRapidaCommand}"
                        MinWidth="170"/>
                <Button Classes="quick-action"
                        Content="➕ Nuevo trabajo"
                        Command="{Binding NuevoTrabajoRapidoCommand}"
                        MinWidth="170"/>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- FILA 2: TARJETAS DE ESTADÍSTICAS                            -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="15" Margin="0,0,0,25">
                
                <!-- Total Clientes -->
                <Border Classes="stat-card">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalClientes}" 
                                   FontSize="36" 
                                   FontWeight="Bold"
                                   Foreground="#64b5f6"/>
                        <TextBlock Text="Clientes" 
                                   FontSize="14" 
                                   Opacity="0.7"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Citas Hoy -->
                <Border Classes="stat-card">
                    <StackPanel>
                        <TextBlock Text="{Binding CitasHoyCount}" 
                                   FontSize="36" 
                                   FontWeight="Bold"
                                   Foreground="#81c784"/>
                        <TextBlock Text="Citas hoy" 
                                   FontSize="14" 
                                   Opacity="0.7"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Ingresos Semana -->
                <Border Classes="stat-card">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding IngresosSemana, StringFormat='{}{0:N0}'}" 
                                       FontSize="36" 
                                       FontWeight="Bold"
                                       Foreground="#fff176"/>
                            <TextBlock Text="€" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Foreground="#fff176"
                                       VerticalAlignment="Top"
                                       Margin="3,5,0,0"/>
                        </StackPanel>
                        <TextBlock Text="Esta semana" 
                                   FontSize="14" 
                                   Opacity="0.7"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Pendientes -->
                <Border Classes="stat-card">
                    <StackPanel>
                        <TextBlock Text="{Binding CitasPendientesConfirmar}" 
                                   FontSize="36" 
                                   FontWeight="Bold"
                                   Foreground="#e57373"/>
                        <TextBlock Text="Por confirmar" 
                                   FontSize="14" 
                                   Opacity="0.7"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- FILA 3: CONTENIDO PRINCIPAL (Citas + Alertas)               -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="3" ColumnDefinitions="2*,*" Margin="0,0,0,25">
                
                <!-- Citas de Hoy -->
                <Border Classes="content-card" Grid.Column="0" Margin="0,0,15,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" 
                                   Text="📅 Citas de hoy" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,15"/>
                        
                        <!-- Lista vacía -->
                        <StackPanel IsVisible="{Binding !CitasHoy.Count}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="🎉" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="No hay citas para hoy" 
                                       FontSize="16" 
                                       Opacity="0.6"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                        
                        <!-- Lista de citas -->
                        <ScrollViewer IsVisible="{Binding CitasHoy.Count}">
                            <ItemsControl ItemsSource="{Binding CitasHoy}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Cita">
                                        <Border Classes="cita-item">
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                
                                                <!-- Hora -->
                                                <StackPanel Grid.Column="0" 
                                                            VerticalAlignment="Center"
                                                            Width="60">
                                                    <TextBlock Text="{Binding HoraInicio, StringFormat='{}{0:hh\\:mm}'}" 
                                                               FontSize="18" 
                                                               FontWeight="Bold"/>
                                                </StackPanel>
                                                
                                                <!-- Info cliente y trabajo -->
                                                <StackPanel Grid.Column="1" 
                                                            Margin="15,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Cliente.NombreCompleto}" 
                                                               FontSize="16" 
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Descripcion}" Opacity="0.7"/>
                                                </StackPanel>
                                                
                                                <!-- Duración -->
                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding DuracionMinutos, StringFormat='{}{0} min'}"
                                                           Opacity="0.6"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,15,0"/>
                                                
                                                <!-- Estado (indicador simple) -->
                                                <Border Grid.Column="3" 
                                                        Width="12" 
                                                        Height="12" 
                                                        CornerRadius="6"
                                                        VerticalAlignment="Center"
                                                        Background="#66bb6a"/>
                                                
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                
                <!-- Alertas -->
                <Border Classes="content-card" Grid.Column="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" 
                                   Text="⚠️ Pendientes" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,15"/>
                        
                        <!-- Sin alertas -->
                        <StackPanel IsVisible="{Binding !Alertas.Count}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="✅" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Todo al día" 
                                       FontSize="16" 
                                       Opacity="0.6"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                        
                        <!-- Lista de alertas -->
                        <ItemsControl ItemsSource="{Binding Alertas}"
                                      IsVisible="{Binding Alertas.Count}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="alerta-item">
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
                
            </Grid>

        </Grid>
    </ScrollViewer>

</UserControl>

