<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ataena.ViewModels"
             xmlns:models="using:Ataena.Models"
             xmlns:views="using:Ataena.Views"
             xmlns:converters="using:Ataena.Converters"
             xmlns:conv="using:Ataena.Converters"
             x:Class="Ataena.Views.ClientesView"
             x:DataType="vm:ClientesViewModel"
             Loaded="OnLoaded">

    <UserControl.Styles>
        <!-- Tarjeta de cliente -->
        <Style Selector="Border.cliente-card">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2a2a3e"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.cliente-card:pointerover">
            <Setter Property="Background" Value="#22223a"/>
            <Setter Property="BorderBrush" Value="#4c3d6e"/>
        </Style>

        <Style Selector="Border.chip">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- Formulario -->
        <Style Selector="Border.form-container">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25"/>
        </Style>
        
        <!-- Campo de formulario -->
        <Style Selector="TextBox.form-field">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <!-- Los estilos de botones están definidos globalmente en App.axaml -->
        
        <!-- Botón peligro -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="#f44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA 0: LISTA DE CLIENTES                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*,Auto" Margin="30">
            
            <!-- Cabecera -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="👥 Clientes" FontSize="28" FontWeight="Bold"/>
                <TextBlock Opacity="0.6" Margin="0,5,0,0">
                    <Run Text="Total: "/>
                    <Run Text="{Binding TotalClientes}"/>
                    <Run Text=" clientes"/>
                </TextBlock>
            </StackPanel>
            
            <!-- Barra de búsqueda y acciones -->
            <Grid Grid.Row="1" RowDefinitions="Auto,Auto" Margin="0,0,0,16">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
                    <TextBox Grid.Column="0"
                             Text="{Binding TextoBusqueda}"
                             Watermark="🔍 Buscar por nombre, apellidos, DNI, teléfono o email..."
                             Margin="0,0,10,0"/>
                    <Button Grid.Column="1"
                            Content="⚠️ Sin RGPD"
                            Classes="btn-secondary"
                            Command="{Binding FiltrarSinConsentimientoCommand}"
                            ToolTip.Tip="Mostrar solo clientes sin consentimiento RGPD firmado"
                            Margin="0,0,10,0"/>
                    <Button Grid.Column="2"
                            Content="➕ Nuevo Cliente"
                            Classes="btn-primary"
                            Command="{Binding NuevoClienteCommand}"/>
                </Grid>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10"
                            Margin="0,12,0,0">
                    <TextBlock Text="Ordenar por"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Opacity="0.65"/>
                    <ComboBox ItemsSource="{Binding OpcionesOrden}"
                              SelectedItem="{Binding OrdenSeleccionado}"
                              MinWidth="190"
                              VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Etiqueta}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
            
            <!-- Lista de clientes -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Clientes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Cliente">
                            <Border Classes="cliente-card"
                                    PointerPressed="OnClienteClick"
                                    Tag="{Binding}">
                                <Grid ColumnDefinitions="Auto,*,Auto">

                                    <!-- Barra de estado (color según ficha del cliente) -->
                                    <Grid Grid.Column="0"
                                          Width="4"
                                          Margin="0,2,14,2"
                                          VerticalAlignment="Stretch"
                                          MinHeight="48">
                                        <!-- Verde: DNI + consentimientos al día -->
                                        <Border CornerRadius="2"
                                                IsVisible="{Binding FichaListaCompleta}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#34d399" Offset="0"/>
                                                    <GradientStop Color="#059669" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <!-- Rojo: sin RGPD -->
                                        <Border CornerRadius="2"
                                                IsVisible="{Binding FichaListaCritica}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#f87171" Offset="0"/>
                                                    <GradientStop Color="#dc2626" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <!-- Naranja: RGPD ok pero falta DNI, imágenes o renovación -->
                                        <Border CornerRadius="2"
                                                IsVisible="{Binding FichaListaParcial}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#fb923c" Offset="0"/>
                                                    <GradientStop Color="#ea580c" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Grid>

                                    <!-- Info principal -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                        <TextBlock Text="{Binding NombreCompleto}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#f1f5f9"/>

                                        <WrapPanel Orientation="Horizontal">
                                            <Border Classes="chip"
                                                    IsVisible="{Binding EsMenorDeEdad}"
                                                    Background="#f59e0b22"
                                                    BorderBrush="#f59e0b55"
                                                    BorderThickness="1"
                                                    Margin="0,0,6,4">
                                                <TextBlock Text="Menor"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#fbbf24"/>
                                            </Border>
                                            <Border Classes="chip"
                                                    IsVisible="{Binding !TieneConsentimientoRGPD}"
                                                    Background="#ef444422"
                                                    BorderBrush="#ef444455"
                                                    BorderThickness="1"
                                                    Margin="0,0,6,4">
                                                <TextBlock Text="Sin RGPD"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#fca5a5"/>
                                            </Border>
                                            <Border Classes="chip"
                                                    IsVisible="{Binding TieneConsentimientoRGPD}"
                                                    Background="#10b98122"
                                                    BorderBrush="#10b98155"
                                                    BorderThickness="1"
                                                    Margin="0,0,6,4">
                                                <TextBlock Text="RGPD"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#6ee7b7"/>
                                            </Border>
                                            <Border Classes="chip"
                                                    IsVisible="{Binding ImagenesChipPendienteFirma}"
                                                    Background="#f9731622"
                                                    BorderBrush="#f9731655"
                                                    BorderThickness="1"
                                                    Margin="0,0,6,4">
                                                <TextBlock Text="Sin imágenes"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#fdba74"/>
                                            </Border>
                                            <Border Classes="chip"
                                                    IsVisible="{Binding ImagenesChipOk}"
                                                    Background="#10b98122"
                                                    BorderBrush="#10b98155"
                                                    BorderThickness="1"
                                                    Margin="0,0,6,4">
                                                <TextBlock Text="Imágenes"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#6ee7b7"/>
                                            </Border>
                                        </WrapPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="14">
                                            <TextBlock FontSize="12" Foreground="#94a3b8"
                                                       IsVisible="{Binding Telefono, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Run Text="📞 "/>
                                                <Run Text="{Binding Telefono}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#94a3b8"
                                                       IsVisible="{Binding Dni, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Run Text="🪪 "/>
                                                <Run Text="{Binding Dni}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#94a3b8"
                                                       IsVisible="{Binding Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Run Text="✉ "/>
                                                <Run Text="{Binding Email}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Edad / fecha -->
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Spacing="2">
                                        <TextBlock Text="{Binding Edad, StringFormat='{}{0} años'}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#cbd5e1"
                                                   HorizontalAlignment="Right"
                                                   IsVisible="{Binding Edad, Converter={x:Static conv:IsNotNullConverter.Instance}}"/>
                                        <TextBlock Text="{Binding FechaNacimiento, StringFormat='dd/MM/yyyy'}"
                                                   FontSize="11"
                                                   Foreground="#64748b"
                                                   HorizontalAlignment="Right"
                                                   IsVisible="{Binding FechaNacimiento, Converter={x:Static conv:IsNotNullConverter.Instance}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Controles de paginación -->
            <Border Grid.Row="3"
                    Background="Transparent"
                    Padding="0,15,0,0"
                    IsVisible="{Binding TotalPaginas, Converter={x:Static converters:GreaterThanConverter.One}}">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                    <!-- Botón página anterior -->
                    <Button Grid.Column="0"
                            Content="◀ Anterior"
                            Command="{Binding PaginaAnteriorCommand}"
                            Classes="btn-secondary"
                            Margin="0,0,15,0"
                            MinWidth="130"
                            Height="36"
                            Padding="20,0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>
                    
                    <!-- Información de página -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <TextBlock Text="Página"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PaginaActual}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="de"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalPaginas}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="("
                                   Opacity="0.7"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalClientes}"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="clientes)"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Botón página siguiente -->
                    <Button Grid.Column="2"
                            Content="Siguiente ▶"
                            Command="{Binding PaginaSiguienteCommand}"
                            Classes="btn-secondary"
                            Margin="15,0,0,0"
                            MinWidth="130"
                            Height="36"
                            Padding="20,0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>
                </Grid>
            </Border>
            
            <!-- Mensaje de error -->
            <Border Grid.Row="3"
                    IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="#3d2a2a"
                    CornerRadius="6"
                    Padding="15"
                    Margin="0,10,0,0">
                <TextBlock Text="{Binding MensajeError}" Foreground="#ef5350"/>
            </Border>
            
        </Grid>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MODAL: FORMULARIO DE CREACIÓN/EDICIÓN DE CLIENTE               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Grid.ColumnSpan="1"
                IsVisible="{Binding MostrarFormulario}"
                Background="#B0000000"
                Padding="40">
            <!-- Modal centrado con glow suave -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="540"
                    MaxWidth="660"
                    MaxHeight="800"
                    Background="#020617"
                    CornerRadius="18"
                    BoxShadow="0 0 80 0 #50d946ef, 0 0 120 0 #40ec4899">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Cabecera del modal -->
                    <Border Grid.Row="0"
                            Background="#111827"
                            Padding="28,22"
                            CornerRadius="18,18,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TituloFormulario}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    FontSize="16"
                                    Width="36"
                                    Height="36"
                                    Background="Transparent"
                                    Foreground="#9ca3af"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Command="{Binding CancelarEdicionCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Contenido scrollable -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="28,24,40,24"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <!-- Margen inferior generoso para que los últimos campos (checkboxes) no queden ocultos tras el footer -->
                        <StackPanel Margin="0,0,0,80">
                            <!-- Nombre -->
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="Nombre *" Opacity="0.7" Margin="0,0,0,5"/>
                                <TextBox Classes="form-field"
                                         Text="{Binding Nombre}"
                                         Watermark="Nombre"
                                         BorderBrush="{Binding ErrorNombre, Converter={x:Static conv:CampoErrorBorderBrushConverter.Instance}}"
                                         BorderThickness="{Binding ErrorNombre, Converter={x:Static conv:CampoErrorBorderThicknessConverter.Instance}}"/>
                                <TextBlock Text="{Binding ErrorNombre}"
                                           Foreground="#ef5350" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                           IsVisible="{Binding ErrorNombre, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>

                            <!-- Apellidos -->
                            <StackPanel Margin="16,0,0,15">
                                <TextBlock Text="Apellidos *" Opacity="0.7" Margin="0,0,0,5"/>
                                <TextBox Classes="form-field"
                                         Text="{Binding Apellidos}"
                                         Watermark="Apellidos"
                                         BorderBrush="{Binding ErrorApellidos, Converter={x:Static conv:CampoErrorBorderBrushConverter.Instance}}"
                                         BorderThickness="{Binding ErrorApellidos, Converter={x:Static conv:CampoErrorBorderThicknessConverter.Instance}}"/>
                                <TextBlock Text="{Binding ErrorApellidos}"
                                           Foreground="#ef5350" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                           IsVisible="{Binding ErrorApellidos, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>

                            <!-- Teléfono -->
                            <StackPanel Margin="16,0,0,15">
                                <TextBlock Text="Teléfono" Opacity="0.7" Margin="0,0,0,5"/>
                                <TextBox Classes="form-field"
                                         Text="{Binding Telefono}"
                                         Watermark="612 345 678 (opcional)"
                                         BorderBrush="{Binding ErrorTelefono, Converter={x:Static conv:CampoErrorBorderBrushConverter.Instance}}"
                                         BorderThickness="{Binding ErrorTelefono, Converter={x:Static conv:CampoErrorBorderThicknessConverter.Instance}}"/>
                                <TextBlock Text="{Binding ErrorTelefono}"
                                           Foreground="#ef5350" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                           IsVisible="{Binding ErrorTelefono, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>

                            <!-- Email -->
                            <StackPanel Margin="16,0,0,15">
                                <TextBlock Text="Email" Opacity="0.7" Margin="0,0,0,5"/>
                                <TextBox Classes="form-field"
                                         Text="{Binding Email}"
                                         Watermark="cliente@email.com"
                                         BorderBrush="{Binding ErrorEmail, Converter={x:Static conv:CampoErrorBorderBrushConverter.Instance}}"
                                         BorderThickness="{Binding ErrorEmail, Converter={x:Static conv:CampoErrorBorderThicknessConverter.Instance}}"/>
                                <TextBlock Text="{Binding ErrorEmail}"
                                           Foreground="#ef5350" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                           IsVisible="{Binding ErrorEmail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>

                            <!-- DNI/NIE/Pasaporte -->
                            <StackPanel Margin="16,0,0,15">
                                <TextBlock Text="DNI/NIE/Pasaporte *" Opacity="0.7" Margin="0,0,0,5"/>
                                <TextBox Classes="form-field"
                                         Text="{Binding Dni}"
                                         Watermark="12345678A, X1234567L o pasaporte"
                                         BorderBrush="{Binding ErrorDni, Converter={x:Static conv:CampoErrorBorderBrushConverter.Instance}}"
                                         BorderThickness="{Binding ErrorDni, Converter={x:Static conv:CampoErrorBorderThicknessConverter.Instance}}"/>
                                <TextBlock Text="{Binding ErrorDni}"
                                           Foreground="#ef5350" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                           IsVisible="{Binding ErrorDni, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>

                            <!-- Fecha nacimiento -->
                            <StackPanel Margin="16,0,0,15">
                            <TextBlock Text="Fecha de nacimiento * (DD/MM/AAAA)" Opacity="0.7" Margin="0,0,0,5"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding FechaNacimientoTexto, Mode=TwoWay}"
                                         Watermark="DDMMYYYY (ej: 15031990)"
                                         Classes="form-field"
                                         HorizontalAlignment="Stretch"
                                         Name="FechaNacimientoTextBox"
                                         TextChanged="OnFechaNacimientoTextChanged"
                                         BorderBrush="{Binding ErrorFechaNacimiento, Converter={x:Static conv:CampoErrorBorderBrushConverter.Instance}}"
                                         BorderThickness="{Binding ErrorFechaNacimiento, Converter={x:Static conv:CampoErrorBorderThicknessConverter.Instance}}"/>
                                <Button Grid.Column="1"
                                        Content="📅"
                                        Width="44"
                                        Height="44"
                                        Margin="8,0,0,0"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        FontSize="18"
                                        Background="#1f2937"
                                        BorderBrush="#374151"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Click="OnAbrirCalendarioFechaNacimiento">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Background" Value="#374151"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                            </Grid>
                            <TextBlock Text="{Binding ErrorFechaNacimiento}"
                                       Foreground="#ef5350" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                       IsVisible="{Binding ErrorFechaNacimiento, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                            <!-- Popup con DatePicker -->
                            <Popup Name="FechaNacimientoPopup"
                                   PlacementTarget="{Binding #FechaNacimientoTextBox}"
                                   Placement="Bottom"
                                   IsLightDismissEnabled="True"
                                   Width="320">
                                <Border Background="#1e1e2e"
                                        CornerRadius="8"
                                        Padding="0"
                                        BorderBrush="#374151"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <!-- Header con mes y año -->
                                        <Border Background="#111827"
                                                CornerRadius="8,8,0,0"
                                                Padding="16,12">
                                            <TextBlock Name="MesAnioHeader"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"/>
                                        </Border>
                                        <!-- DatePicker -->
                                        <DatePicker SelectedDate="{Binding FechaNacimiento}"
                                                     HorizontalAlignment="Stretch"
                                                     Padding="10"
                                                     Name="FechaNacimientoDatePicker"
                                                     SelectedDateChanged="OnFechaNacimientoSelectedDateChanged"/>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <!-- Alergias -->
                            <TextBlock Text="Alergias (importante para tintas)" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Classes="form-field"
                                     Text="{Binding Alergias}"
                                     Watermark="Ninguna conocida"
                                     AcceptsReturn="True"
                                     Height="60"
                                     TextWrapping="Wrap"/>

                            <!-- Notas -->
                            <TextBlock Text="Notas" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Classes="form-field"
                                     Text="{Binding Notas}"
                                     Watermark="Notas adicionales..."
                                     AcceptsReturn="True"
                                     Height="80"
                                     TextWrapping="Wrap"/>

                            <!-- Datos del Tutor (visible si es menor de edad) -->
                            <Border Background="#1f2937"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="16,16,16,0"
                                    IsVisible="{Binding EsMenorFormulario}">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="👨‍👩‍👧 Datos del Tutor/Representante Legal"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#f59e0b"/>
                                        <TextBlock Text="(requerido para menores)"
                                                   FontSize="11"
                                                   Opacity="0.6"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Nombre del tutor *" Opacity="0.7" FontSize="12"/>
                                            <TextBox Text="{Binding NombreTutor}"
                                                     Watermark="Nombre"
                                                     Height="36"
                                                     BorderBrush="{Binding ErrorNombreTutor, Converter={x:Static conv:CampoErrorBorderBrushConverter.Instance}}"
                                                     BorderThickness="{Binding ErrorNombreTutor, Converter={x:Static conv:CampoErrorBorderThicknessConverter.Instance}}"/>
                                            <TextBlock Text="{Binding ErrorNombreTutor}"
                                                       Foreground="#ef5350" FontSize="10" TextWrapping="Wrap"
                                                       IsVisible="{Binding ErrorNombreTutor, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Apellidos del tutor *" Opacity="0.7" FontSize="12"/>
                                            <TextBox Text="{Binding ApellidosTutor}"
                                                     Watermark="Apellidos"
                                                     Height="36"
                                                     BorderBrush="{Binding ErrorApellidosTutor, Converter={x:Static conv:CampoErrorBorderBrushConverter.Instance}}"
                                                     BorderThickness="{Binding ErrorApellidosTutor, Converter={x:Static conv:CampoErrorBorderThicknessConverter.Instance}}"/>
                                            <TextBlock Text="{Binding ErrorApellidosTutor}"
                                                       Foreground="#ef5350" FontSize="10" TextWrapping="Wrap"
                                                       IsVisible="{Binding ErrorApellidosTutor, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="DNI del tutor *" Opacity="0.7" FontSize="12"/>
                                            <TextBox Text="{Binding DniTutor}"
                                                     Watermark="12345678A"
                                                     Height="36"
                                                     BorderBrush="{Binding ErrorDniTutor, Converter={x:Static conv:CampoErrorBorderBrushConverter.Instance}}"
                                                     BorderThickness="{Binding ErrorDniTutor, Converter={x:Static conv:CampoErrorBorderThicknessConverter.Instance}}"/>
                                            <TextBlock Text="{Binding ErrorDniTutor}"
                                                       Foreground="#ef5350" FontSize="10" TextWrapping="Wrap"
                                                       IsVisible="{Binding ErrorDniTutor, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Teléfono del tutor" Opacity="0.7" FontSize="12"/>
                                            <TextBox Text="{Binding TelefonoTutor}"
                                                     Watermark="600123456"
                                                     Height="36"
                                                     BorderBrush="{Binding ErrorTelefonoTutor, Converter={x:Static conv:CampoErrorBorderBrushConverter.Instance}}"
                                                     BorderThickness="{Binding ErrorTelefonoTutor, Converter={x:Static conv:CampoErrorBorderThicknessConverter.Instance}}"/>
                                            <TextBlock Text="{Binding ErrorTelefonoTutor}"
                                                       Foreground="#ef5350" FontSize="10" TextWrapping="Wrap"
                                                       IsVisible="{Binding ErrorTelefonoTutor, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Fotos en trabajos / consentimiento de imágenes (nuevo y edición) -->
                            <Border Background="#0f172a"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="16,18,16,0"
                                    BorderBrush="#334155"
                                    BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <CheckBox IsChecked="{Binding PermiteFotosTrabajo}"
                                              Content="Permitir fotos del trabajo y consentimiento de uso de imágenes (antes/después)"
                                              FontSize="13"
                                              FontWeight="SemiBold"/>
                                    <TextBlock Text="Si el cliente no quiere fotos, desmarca esta opción: no se podrán tomar fotos en sus trabajos ni firmar este consentimiento hasta que lo actives de nuevo."
                                               FontSize="11"
                                               Opacity="0.65"
                                               TextWrapping="Wrap"
                                               Margin="28,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Consentimiento RGPD (solo para nuevos clientes) -->
                            <CheckBox IsVisible="{Binding !EsEdicion}"
                                      IsChecked="{Binding FirmarConsentimientoRGPD}"
                                      Content="📝 Firmar consentimiento RGPD (opcional)"
                                      Margin="16,20,0,8"
                                      FontSize="13"
                                      FontWeight="SemiBold"/>
                            
                            <!-- Consentimiento de imágenes (solo para nuevos clientes) -->
                            <CheckBox IsVisible="{Binding !EsEdicion}"
                                      IsChecked="{Binding SolicitarConsentimientoImagenes}"
                                      IsEnabled="{Binding PermiteFotosTrabajo}"
                                      Content="📸 Solicitar consentimiento de uso de imágenes (opcional)"
                                      Margin="16,8,0,20"
                                      FontSize="13"/>

                            <!-- Mensaje de error -->
                            <Border IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="#3d2a2a"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,0,0,15">
                                <TextBlock Text="{Binding MensajeError}" 
                                           Foreground="#ef5350"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <!-- Espaciador final para indicar el final del contenido -->
                            <Border Height="60"
                                    Background="Transparent"
                                    Margin="0,24,0,0">
                                <Border Height="1"
                                        Background="#1f2937"
                                        Opacity="0.3"
                                        VerticalAlignment="Top"
                                        Margin="0,20,0,0"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer botones -->
                    <Border Grid.Row="2"
                            Background="#111827"
                            Padding="28,20"
                            CornerRadius="0,0,18,18">
                        <Grid ColumnDefinitions="Auto,*">
                            <Button Grid.Column="0"
                                    Content="🗑️ Eliminar cliente"
                                    Classes="btn-danger"
                                    Command="{Binding EliminarClienteCommand}"
                                    IsVisible="{Binding EsEdicion}"
                                    MinWidth="150"
                                    Height="42"
                                    Padding="12,0"
                                    HorizontalAlignment="Left"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="12">
                                <Button Content="Cancelar"
                                        Classes="btn-secondary"
                                        Command="{Binding CancelarEdicionCommand}"
                                        MinWidth="130"
                                        Height="42"
                                        Padding="12,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                                <Button Content="💾 Guardar"
                                        Classes="btn-primary"
                                        Command="{Binding GuardarClienteCommand}"
                                        MinWidth="130"
                                        Height="42"
                                        Padding="12,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                <!-- Aviso centrado de validación (campos obligatorios) -->
                <Border Grid.RowSpan="3"
                        IsVisible="{Binding MostrarAlertaValidacionFormulario}"
                        Background="#CC000000"
                        ZIndex="200">
                    <Border Background="#450a0a"
                            BorderBrush="#ef4444"
                            BorderThickness="2"
                            CornerRadius="14"
                            Padding="28,24"
                            MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BoxShadow="0 8 32 0 #80ef4444">
                        <StackPanel Spacing="14">
                            <TextBlock Text="⚠️"
                                       FontSize="36"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Revisa el formulario"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#fecaca"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding MensajeAlertaValidacionFormulario}"
                                       Foreground="#fca5a5"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       FontSize="14"/>
                            <Button Content="Entendido"
                                    Classes="btn-primary"
                                    Command="{Binding CerrarAlertaValidacionFormularioCommand}"
                                    HorizontalAlignment="Center"
                                    MinWidth="140"
                                    Height="40"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>
                </Grid>
            </Border>
        </Border>
        
        <!-- Overlay de carga -->
        <Border Grid.ColumnSpan="2"
                IsVisible="{Binding Cargando}"
                Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Cargando..." Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MODAL: FICHA DEL CLIENTE                                         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Grid.ColumnSpan="1"
                IsVisible="{Binding MostrarFicha}"
                Background="#B0000000"
                Padding="40">
            <!-- Modal centrado con glow suave (altura completa para permitir scroll interno) -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    MinWidth="700"
                    MaxWidth="900"
                    Margin="0,40,0,40"
                    Background="#020617"
                    CornerRadius="18"
                    BoxShadow="0 0 80 0 #50d946ef, 0 0 120 0 #40ec4899">
                <Grid RowDefinitions="Auto,*,Auto" MinHeight="600" MaxHeight="1200">
                    <!-- Cabecera del modal -->
                    <Border Grid.Row="0"
                            Background="#111827"
                            Padding="28,22"
                            CornerRadius="18,18,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding ClienteSeleccionado.NombreCompleto, TargetNullValue='Ficha del Cliente'}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <!-- Badge de menor de edad -->
                                    <Border IsVisible="{Binding ClienteSeleccionado.EsMenorDeEdad}"
                                            Background="#f59e0b"
                                            CornerRadius="6"
                                            Padding="8,4"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="🔞 MENOR DE EDAD"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                    <!-- Badge de renovación pendiente -->
                                    <Border IsVisible="{Binding ClienteSeleccionado.TieneConsentimientosPendientesRenovacion}"
                                            Background="#ef5350"
                                            CornerRadius="6"
                                            Padding="8,4"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="⚠️ Renovar consentimientos"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding ClienteSeleccionado.Telefono}"
                                           FontSize="13"
                                           Opacity="0.7"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="✏️ Editar"
                                        Classes="btn-secondary"
                                        Command="{Binding EditarClienteCommand}"
                                        MinWidth="120"
                                        Height="40"
                                        Padding="16,0"
                                        FontSize="12"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                                <Button Content="✕"
                                        FontSize="16"
                                        Width="36"
                                        Height="36"
                                        Background="Transparent"
                                        Foreground="#9ca3af"
                                        BorderThickness="0"
                                        CornerRadius="18"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Command="{Binding CerrarFichaCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Contenido scrollable -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="28,24,28,24"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="24" Margin="0,0,0,40">
                            
                            <!-- Información del Cliente -->
                            <Border Background="#111827"
                                    CornerRadius="12"
                                    Padding="20">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="📋 Información del Cliente"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,8"/>
                                    
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre:" Opacity="0.7" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ClienteSeleccionado.NombreCompleto}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Teléfono:" Opacity="0.7" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClienteSeleccionado.Telefono}" Margin="0,0,0,8"/>
                                        
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:" Opacity="0.7" Margin="0,0,12,8"
                                                   IsVisible="{Binding ClienteSeleccionado.Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ClienteSeleccionado.Email}" Margin="0,0,0,8"
                                                   IsVisible="{Binding ClienteSeleccionado.Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="DNI/NIE/Pasaporte:" Opacity="0.7" Margin="0,0,12,8"
                                                   IsVisible="{Binding ClienteSeleccionado.Dni, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ClienteSeleccionado.Dni}" Margin="0,0,0,8"
                                                   IsVisible="{Binding ClienteSeleccionado.Dni, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Fecha Nacimiento:" Opacity="0.7" Margin="0,0,12,8"
                                                   IsVisible="{Binding ClienteSeleccionado.FechaNacimiento, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ClienteSeleccionado.FechaNacimientoConEdad}" Margin="0,0,0,8"
                                                   IsVisible="{Binding ClienteSeleccionado.FechaNacimiento, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Alergias:" Opacity="0.7" Margin="0,0,12,0"
                                                   IsVisible="{Binding ClienteSeleccionado.Alergias, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ClienteSeleccionado.Alergias}" TextWrapping="Wrap"
                                                   IsVisible="{Binding ClienteSeleccionado.Alergias, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Datos del Tutor (solo visible si es menor de edad) -->
                            <Border Background="#111827"
                                    CornerRadius="12"
                                    Padding="20"
                                    IsVisible="{Binding ClienteSeleccionado.EsMenorDeEdad}">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="👨‍👩‍👧 Datos del Tutor/Representante Legal"
                                                   FontSize="18"
                                                   FontWeight="Bold"/>
                                        <!-- Indicador de datos faltantes -->
                                        <Border IsVisible="{Binding ClienteSeleccionado.RequiereDatosTutor}"
                                                Background="#ef5350"
                                                CornerRadius="6"
                                                Padding="8,4"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="⚠️ Datos incompletos"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                    
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre:" Opacity="0.7"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                                   Text="{Binding ClienteSeleccionado.NombreCompletoTutor, TargetNullValue='No especificado'}"
                                                   FontWeight="SemiBold"/>
                                        
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="DNI:" Opacity="0.7"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" 
                                                   Text="{Binding ClienteSeleccionado.DniTutor, TargetNullValue='No especificado'}"/>
                                        
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Teléfono:" Opacity="0.7"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" 
                                                   Text="{Binding ClienteSeleccionado.TelefonoTutor, TargetNullValue='No especificado'}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Consentimientos -->
                            <Border Background="#111827"
                                    CornerRadius="12"
                                    Padding="20">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                        <TextBlock Text="📝 Consentimientos"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8"/>
                                        <!-- Chips de estado RGPD / Imágenes -->
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Background="{Binding ClienteSeleccionado.TieneConsentimientoRGPD, Converter={StaticResource BoolToTextConverter}, ConverterParameter='#10b981|#ef5350'}"
                                                    CornerRadius="12"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ClienteSeleccionado.TieneConsentimientoRGPD, Converter={StaticResource BoolToTextConverter}, ConverterParameter='✅ RGPD|⚠️ Sin RGPD'}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                            </Border>
                                            <Border IsVisible="{Binding ClienteSeleccionado.ImagenesChipSinFotosAcordado}"
                                                    Background="#6b7280"
                                                    CornerRadius="12"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="📸 Sin fotos (cliente)"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                            </Border>
                                            <Border IsVisible="{Binding ClienteSeleccionado.ImagenesChipOk}"
                                                    Background="#10b981"
                                                    CornerRadius="12"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="📸 Imágenes OK"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                            </Border>
                                            <Border IsVisible="{Binding ClienteSeleccionado.ImagenesChipPendienteFirma}"
                                                    Background="#f97316"
                                                    CornerRadius="12"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="📸 Falta firma"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <ItemsControl ItemsSource="{Binding ConsentimientosCliente}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:Consentimiento">
                                                <Border CornerRadius="8"
                                                        Padding="16"
                                                        Margin="0,0,0,12">
                                                    <Border.Background>
                                                        <Binding Path="NecesitaRenovacion" 
                                                                 Converter="{StaticResource BoolToTextConverter}" 
                                                                 ConverterParameter="#5a2d2d|#1a1a2e"/>
                                                    </Border.Background>
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <StackPanel Grid.Column="0">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="{Binding NombreTipo}"
                                                                           FontSize="15"
                                                                           FontWeight="SemiBold"/>
                                                                <!-- Badge de antigüedad -->
                                                                <Border Background="#374151"
                                                                        CornerRadius="4"
                                                                        Padding="6,2"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding AntiguedadTexto}"
                                                                               FontSize="10"
                                                                               Opacity="0.9"/>
                                                                </Border>
                                                                <!-- Badge de renovación necesaria -->
                                                                <Border IsVisible="{Binding NecesitaRenovacion}"
                                                                        Background="#ef5350"
                                                                        CornerRadius="4"
                                                                        Padding="6,2"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="⚠️ Renovar"
                                                                               FontSize="10"
                                                                               FontWeight="Bold"
                                                                               Foreground="White"/>
                                                                </Border>
                                                                <!-- Badge de consentimiento de menor -->
                                                                <Border IsVisible="{Binding EsConsentimientoMenor}"
                                                                        Background="#f59e0b"
                                                                        CornerRadius="4"
                                                                        Padding="6,2"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="Menor"
                                                                               FontSize="10"
                                                                               FontWeight="Bold"
                                                                               Foreground="White"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding FechaFirma, StringFormat='Firmado el {0:dd/MM/yyyy} a las {0:HH:mm}'}"
                                                                       FontSize="12"
                                                                       Opacity="0.7"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    Spacing="6"
                                                                    IsVisible="{Binding Firmado}">
                                                            <Button Classes="btn-secondary"
                                                                    MinWidth="64"
                                                                    Height="34"
                                                                    Padding="8,0"
                                                                    Command="{Binding $parent[UserControl].DataContext.AbrirConsentimientoCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="Abrir PDF">
                                                                <TextBlock Text="Ver" FontSize="12"/>
                                                            </Button>
                                                            <Button Classes="btn-secondary"
                                                                    MinWidth="76"
                                                                    Height="34"
                                                                    Padding="8,0"
                                                                    Command="{Binding $parent[UserControl].DataContext.RenovarConsentimientoCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="Firmar de nuevo (sustituye al anterior)">
                                                                <TextBlock Text="Renovar" FontSize="12"/>
                                                            </Button>
                                                            <Button Classes="btn-danger"
                                                                    MinWidth="68"
                                                                    Height="34"
                                                                    Padding="8,0"
                                                                    Command="{Binding $parent[UserControl].DataContext.EliminarConsentimientoCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="Eliminar consentimiento y PDF">
                                                                <TextBlock Text="Borrar" FontSize="12"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Spacing="8"
                                                Margin="0,8,0,0">
                                        <Button Content="📝 Firmar RGPD"
                                                Classes="btn-secondary"
                                                IsVisible="{Binding !ClienteSeleccionado.TieneConsentimientoRGPD}"
                                                Command="{Binding FirmarConsentimientoRGPDDesdeFichaCommand}"
                                                CommandParameter="{Binding ClienteSeleccionado}"
                                                Height="36"
                                                MinHeight="36"
                                                Padding="12,0"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"/>
                                        <Button Content="📸 Firmar imágenes"
                                                Classes="btn-secondary"
                                                IsVisible="{Binding ClienteSeleccionado.MostrarAccionFirmarConsentimientoImagenes}"
                                                Command="{Binding FirmarConsentimientoImagenesDesdeFichaCommand}"
                                                CommandParameter="{Binding ClienteSeleccionado}"
                                                Height="36"
                                                MinHeight="36"
                                                Padding="12,0"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="No hay consentimientos firmados"
                                               IsVisible="{Binding !ConsentimientosCliente.Count}"
                                               Opacity="0.5"
                                               FontStyle="Italic"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Trabajos -->
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto"
                                      Margin="0,0,0,8">
                                    <TextBlock Grid.Column="0"
                                               Text="🎨 Historial de Trabajos"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="➕ Nuevo trabajo"
                                            Classes="btn-primary"
                                            Command="{Binding NuevoTrabajoDesdeFichaClienteCommand}"
                                            Height="38"
                                            MinWidth="150"
                                            Padding="14,0"
                                            VerticalContentAlignment="Center"
                                            HorizontalContentAlignment="Center"/>
                                </Grid>
                                
                                <!-- Lista de trabajos (solo si hay alguno) -->
                                <Border Background="#111827"
                                        CornerRadius="12"
                                        Padding="20"
                                        IsVisible="{Binding TrabajosCliente.Count}">
                                    <ItemsControl ItemsSource="{Binding TrabajosCliente}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:Trabajo">
                                                <Border Background="#1a1a2e"
                                                        CornerRadius="8"
                                                        Padding="16"
                                                        Margin="0,0,0,12"
                                                        Cursor="Hand"
                                                        Classes="hover-border"
                                                        PointerPressed="OnTrabajoClick">
                                                    <Border.Styles>
                                                        <Style Selector="Border.hover-border:pointerover">
                                                            <Setter Property="Background" Value="#252547"/>
                                                        </Style>
                                                    </Border.Styles>
                                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding IconoTipo}"
                                                                   FontSize="24"
                                                                   Margin="0,0,16,0"
                                                                   VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Descripcion}"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       Margin="0,0,0,4"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="12" Opacity="0.7">
                                                                <TextBlock Text="{Binding ZonaCuerpo}"
                                                                           IsVisible="{Binding ZonaCuerpo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                                <TextBlock Text="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy}'}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Tipo}"
                                                                   FontSize="12"
                                                                   Opacity="0.6"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                                
                                <!-- Mensaje cuando no hay trabajos -->
                                <TextBlock Text="No hay trabajos registrados"
                                           IsVisible="{Binding !TrabajosCliente.Count}"
                                           Opacity="0.5"
                                           FontStyle="Italic"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Espaciador final para indicar el final del contenido -->
                            <Border Height="60"
                                    Background="Transparent"
                                    Margin="0,24,0,0">
                                <Border Height="1"
                                        Background="#1f2937"
                                        Opacity="0.3"
                                        VerticalAlignment="Top"
                                        Margin="0,20,0,0"/>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Border Grid.Row="2"
                            Background="#111827"
                            Padding="28,20"
                            CornerRadius="0,0,18,18">
                        <Button Content="Cerrar"
                                Classes="btn-secondary"
                                Command="{Binding CerrarFichaCommand}"
                                HorizontalAlignment="Right"
                                MinWidth="120"
                                Height="42"
                                Padding="12,0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- Modal de firma de consentimientos (ZIndex alto para estar sobre todo) -->
        <views:ConsentimientoFirmaView Grid.Row="0"
                                        Grid.RowSpan="99"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="99"
                                        ZIndex="2000"
                                        DataContext="{Binding ConsentimientoFirmaVM}"/>
        
    </Grid>

</UserControl>

