<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Ataena.ViewModels"
             x:Class="Ataena.Views.FotoTrabajoView"
             x:DataType="vm:FotoTrabajoViewModel">
  <Grid IsVisible="{Binding EsVisible}"
        Background="#80000000">
    <Border Width="620"
            MaxHeight="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#020617"
            CornerRadius="18"
            Padding="24">
      <Grid RowDefinitions="Auto,*,Auto,Auto">
        <!-- Cabecera -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Margin="0,0,0,16">
          <TextBlock Grid.Column="0"
                     Text="{Binding TituloModal}"
                     FontSize="22"
                     FontWeight="Bold"
                     VerticalAlignment="Center"/>
          <Button Grid.Column="1"
                  Content="✖"
                  Command="{Binding CerrarCommand}"
                  Classes="btn-icon"
                  Width="32"
                  Height="32"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Contenido principal -->
        <Grid Grid.Row="1"
              ColumnDefinitions="2*,*"
              ColumnSpacing="20">
          <!-- Lado QR -->
          <StackPanel Grid.Column="0"
                      Spacing="8">
            <TextBlock Text="Escanea este código QR con el móvil para hacer la foto"
                       FontSize="14"
                       Opacity="0.8"
                       TextWrapping="Wrap"/>
            <Border Width="260"
                    Height="260"
                    Margin="0,8,0,8"
                    Background="#020617"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
              <Image Source="{Binding QrCodeImage}"
                     Stretch="Uniform"
                     Margin="8"/>
            </Border>
            <TextBlock Text="{Binding UrlFoto}"
                       FontSize="12"
                       Opacity="0.7"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding EstadoConexion}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
          </StackPanel>

          <!-- Lado previews -->
          <StackPanel Grid.Column="1"
                      Spacing="8">
            <TextBlock Text="Fotos actuales"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <StackPanel Orientation="Vertical"
                        Spacing="6">
              <TextBlock Text="Antes"
                         FontSize="12"
                         Opacity="0.7"/>
              <Border Width="180"
                      Height="110"
                      Background="#020617"
                      CornerRadius="8"
                      BorderBrush="#1f2937"
                      BorderThickness="1">
                <Image Source="{Binding PreviewFotoAntes}"
                       Stretch="UniformToFill"
                       ClipToBounds="True"/>
              </Border>
            </StackPanel>

            <StackPanel Orientation="Vertical"
                        Spacing="6"
                        Margin="0,10,0,0">
              <TextBlock Text="Después"
                         FontSize="12"
                         Opacity="0.7"/>
              <Border Width="180"
                      Height="110"
                      Background="#020617"
                      CornerRadius="8"
                      BorderBrush="#1f2937"
                      BorderThickness="1">
                <Image Source="{Binding PreviewFotoDespues}"
                       Stretch="UniformToFill"
                       ClipToBounds="True"/>
              </Border>
            </StackPanel>
          </StackPanel>
        </Grid>

        <!-- Mensaje de error -->
        <Border Grid.Row="2"
                IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="#3d2a2a"
                CornerRadius="6"
                Padding="10"
                Margin="0,16,0,0">
          <TextBlock Text="{Binding MensajeError}"
                     Foreground="#ef5350"
                     TextWrapping="Wrap"/>
        </Border>

        <!-- Botón Cancelar -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="12"
                    Margin="0,16,0,0">
          <Button Content="Cancelar"
                  Classes="btn-secondary"
                  Command="{Binding CerrarCommand}"
                  MinWidth="120"
                  Height="40"
                  Padding="16,0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>


