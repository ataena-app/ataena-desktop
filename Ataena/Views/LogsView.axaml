<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ataena.ViewModels"
             x:Class="Ataena.Views.LogsView"
             x:DataType="vm:LogsViewModel">

    <UserControl.Styles>
        <Style Selector="Border.log-container">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
        
        <!-- Los estilos de botones están definidos globalmente en App.axaml -->
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="30">
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- CABECERA                                                         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📋 Logs del Sistema" FontSize="28" FontWeight="Bold"/>
            <TextBlock Opacity="0.6" Margin="0,5,0,0">
                <Run Text="Carpeta: "/>
                <Run Text="{Binding RutaCarpetaLogs}"/>
            </TextBlock>
        </StackPanel>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- CONTROLES (Selector de archivo y botones)                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,15">
            
            <!-- Selector de archivo -->
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding ArchivosLog}"
                      SelectedItem="{Binding ArchivoSeleccionado}"
                      Margin="0,0,10,0"
                      PlaceholderText="Selecciona un archivo de log..."/>
            
            <!-- Botón cargar -->
            <Button Grid.Column="1"
                    Content="🔄 Cargar"
                    Classes="btn-primary"
                    Command="{Binding CargarLogCommand}"
                    Margin="0,0,10,0"/>
            
            <!-- Botón exportar -->
            <Button Grid.Column="2"
                    Content="💾 Exportar"
                    Classes="btn-secondary"
                    Command="{Binding ExportarLogCommand}"
                    Margin="0,0,10,0"/>
            
            <!-- Botón abrir carpeta -->
            <Button Grid.Column="3"
                    Content="📁 Abrir Carpeta"
                    Classes="btn-secondary"
                    Command="{Binding AbrirCarpetaLogsCommand}"/>
            
        </Grid>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- CONTENIDO DEL LOG                                                -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Classes="log-container">
            <ScrollViewer>
                <TextBox Text="{Binding ContenidoLog}"
                         IsReadOnly="True"
                         FontFamily="Consolas, Courier New"
                         FontSize="12"
                         Background="Transparent"
                         Foreground="#e0e0e0"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"/>
            </ScrollViewer>
        </Border>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MENSAJE DE ESTADO                                                -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                IsVisible="{Binding Mensaje, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="#2a2a3e"
                CornerRadius="6"
                Padding="15"
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="ℹ️" FontSize="18"/>
                <TextBlock Text="{Binding Mensaje}" 
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <!-- Overlay de carga -->
        <Border Grid.Row="2"
                IsVisible="{Binding Cargando}"
                Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Cargando log..." Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        
    </Grid>

</UserControl>

