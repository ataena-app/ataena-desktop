<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ataena.ViewModels"
             xmlns:models="using:Ataena.Models"
             xmlns:views="using:Ataena.Views"
             xmlns:converters="using:Ataena.Converters"
             x:Class="Ataena.Views.TrabajosView"
             x:DataType="vm:TrabajosViewModel"
             Loaded="OnLoaded">

    <UserControl.Styles>
        <!-- Tarjeta de trabajo -->
        <Style Selector="Border.trabajo-card">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="Border.trabajo-card:pointerover">
            <Setter Property="Background" Value="#2a2a3e"/>
        </Style>
        
        <!-- Formulario -->
        <Style Selector="Border.form-container">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25"/>
        </Style>
        
        <!-- Campo de formulario -->
        <Style Selector="TextBox.form-field">
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        
        <!-- Los estilos de botones están definidos globalmente en App.axaml -->
        
        <!-- Botón peligro -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="#f44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto">
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA 0: LISTA DE TRABAJOS                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto,*,Auto" Margin="30">
            
            <!-- Cabecera -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="💼 Trabajos" FontSize="28" FontWeight="Bold"/>
                <TextBlock Opacity="0.6" Margin="0,5,0,0">
                    <Run Text="Total: "/>
                    <Run Text="{Binding TotalTrabajos}"/>
                    <Run Text=" trabajos"/>
                </TextBlock>
            </StackPanel>
            
            <!-- Barra de búsqueda, filtro y acciones -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,20">
                <TextBox Grid.Column="0"
                         Text="{Binding TextoBusqueda}"
                         Watermark="🔍 Buscar por descripción, zona, cliente o teléfono..."
                         Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Clientes}"
                          SelectedItem="{Binding ClienteFiltro}"
                          Width="200"
                          Margin="0,0,10,0"
                          PlaceholderText="Filtrar por cliente">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NombreCompleto}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2"
                        Content="Buscar"
                        Command="{Binding CargarTrabajosCommand}"
                        Margin="0,0,10,0"/>
                <Button Grid.Column="3"
                        Content="➕ Nuevo Trabajo"
                        Classes="btn-primary"
                        Command="{Binding NuevoTrabajoCommand}"/>
            </Grid>
            
            <!-- Lista de trabajos -->
            <ScrollViewer Grid.Row="2">
                <ItemsControl ItemsSource="{Binding Trabajos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Trabajo">
                            <Border Classes="trabajo-card"
                                    PointerPressed="OnTrabajoClick"
                                    Tag="{Binding}">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    
                                    <!-- Icono del tipo -->
                                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                        <TextBlock Text="{Binding IconoTipo}" 
                                                   FontSize="32" 
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Tipo}" 
                                                   FontSize="12" 
                                                   Opacity="0.6"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Descripcion}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"/>
                                            <!-- Indicador de consentimiento -->
                                            <Border Grid.Column="1"
                                                    IsVisible="{Binding !TieneConsentimiento}"
                                                    Background="#ef5350"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⚠️ Sin consentimiento"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                            <Border Grid.Column="1"
                                                    IsVisible="{Binding TieneConsentimiento}"
                                                    Background="#10b981"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="✅ Consentimiento"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="15" Opacity="0.7" Margin="0,5,0,0">
                                            <TextBlock>
                                                <Run Text="📍 "/>
                                                <Run Text="{Binding ZonaCuerpo, TargetNullValue='Sin zona'}"/>
                                            </TextBlock>
                                            <TextBlock IsVisible="{Binding Estilo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Run Text="🎨 "/>
                                                <Run Text="{Binding Estilo}"/>
                                            </TextBlock>
                                            <TextBlock IsVisible="{Binding Tamano, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Run Text="📏 "/>
                                                <Run Text="{Binding Tamano}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="15" Opacity="0.6" Margin="0,5,0,0">
                                            <TextBlock>
                                                <Run Text="👤 "/>
                                                <Run Text="{Binding Cliente.NombreCompleto}"/>
                                            </TextBlock>
                                            <TextBlock>
                                                <Run Text="📅 "/>
                                                <Run Text="{Binding FechaCreacion, StringFormat='{}{0:dd/MM/yyyy}'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Acciones -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock IsVisible="{Binding Colores}"
                                                   Text="🎨 Color"
                                                   FontSize="11"
                                                   Opacity="0.7"
                                                   Margin="0,5,0,0"/>
                                        <!-- Botón para firmar consentimiento -->
                                        <Button IsVisible="{Binding !TieneConsentimiento}"
                                                MinWidth="168"
                                                MinHeight="40"
                                                Padding="12,8"
                                                Margin="0,8,0,0"
                                                Tag="{Binding}"
                                                Click="OnFirmarConsentimientoClick"
                                                Classes="btn-primary"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                ToolTip.Tip="Firmar consentimiento de trabajo">
                                            <TextBlock Text="📝 Firmar consentimiento"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       MaxWidth="160"/>
                                        </Button>
                                    </StackPanel>
                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Mensaje de error -->
            <Border Grid.Row="3"
                    IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="#3d2a2a"
                    CornerRadius="6"
                    Padding="15"
                    Margin="0,10,0,0">
                <TextBlock Text="{Binding MensajeError}" Foreground="#ef5350"/>
            </Border>
            
        </Grid>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MODAL: FORMULARIO DE CREACIÓN/EDICIÓN DE TRABAJO                -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                IsVisible="{Binding MostrarFormulario}"
                Background="#B0000000"
                Padding="40">
            <!-- Modal centrado con glow suave (altura completa para permitir scroll interno) -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="540"
                    MaxWidth="660"
                    MaxHeight="800"
                    Background="#020617"
                    CornerRadius="18"
                    BoxShadow="0 0 80 0 #50d946ef, 0 0 120 0 #40ec4899">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Cabecera del modal -->
                    <Border Grid.Row="0"
                            Background="#111827"
                            Padding="28,22"
                            CornerRadius="18,18,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TituloFormulario}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    FontSize="16"
                                    Width="36"
                                    Height="36"
                                    Background="Transparent"
                                    Foreground="#9ca3af"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Command="{Binding CancelarEdicionCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Contenido scrollable -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="28,24,40,24"
                                  VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Disabled">
                        <!-- Margen inferior generoso para que el último campo no quede oculto tras el footer -->
                        <StackPanel Margin="0,0,0,80">

                            <!-- Aviso si tiene consentimiento firmado (solo en edición) -->
                            <Border IsVisible="{Binding MostrarAvisoNoModificable}"
                                    Background="#3d2a2a"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,20"
                                    BorderBrush="#ef5350"
                                    BorderThickness="2">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="⚠️ Consentimiento de trabajo firmado"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="#ef5350"/>
                                    <TextBlock Text="Los datos de arriba ya no se pueden cambiar. Solo puedes ver o enviar el PDF y, más abajo, añadir o quitar fotos del trabajo."
                                               FontSize="12"
                                               Foreground="#ffcdd2"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Cliente / tipo / descripción (consentimiento) + notas (solo internas). Desactivado si ya hay consentimiento firmado. -->
                            <StackPanel IsEnabled="{Binding TrabajoCamposPrincipalesHabilitados}">

                            <!-- Cliente (búsqueda + desplegable) -->
                            <TextBlock Text="Cliente *" Opacity="0.7" Margin="0,0,0,5"/>
                            <TextBox Name="ClienteBusquedaTrabajoTextBox"
                                     Text="{Binding TextoBusquedaClienteFormulario, Mode=TwoWay}"
                                     Watermark="Buscar por nombre o teléfono…"
                                     Classes="form-field"
                                     Margin="0,0,0,8"
                                     TextChanged="OnClienteBusquedaTrabajoTextChanged"/>
                            <ComboBox Name="ClienteTrabajoComboBox"
                                      ItemsSource="{Binding ClientesFiltradosFormulario}"
                                      SelectedItem="{Binding ClienteSeleccionado}"
                                      MinWidth="260">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding NombreCompleto}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Telefono}"
                                                       FontSize="11"
                                                       Opacity="0.7"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Tipo -->
                            <TextBlock Text="Tipo *" Opacity="0.7" Margin="16,16,0,5"/>
                            <ComboBox SelectedItem="{Binding TipoTrabajo}"
                                      Height="40">
                                <ComboBox.Items>
                                    <x:Static Member="models:TipoTrabajo.Tatuaje"/>
                                    <x:Static Member="models:TipoTrabajo.Piercing"/>
                                </ComboBox.Items>
                            </ComboBox>

                            <!-- Descripción -->
                            <TextBlock Text="Descripción * (aparece en el consentimiento)" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Text="{Binding Descripcion}"
                                     Watermark="Ej.: tigre en el cuello, piercing ombligo…"
                                     Classes="form-field"/>

                            <!-- Notas internas: no van al PDF de consentimiento -->
                            <TextBlock Text="Notas (solo estudio, no en el consentimiento)" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Text="{Binding Notas}"
                                     Watermark="Notas internas…"
                                     AcceptsReturn="True"
                                     Height="80"
                                     TextWrapping="Wrap"
                                     Margin="16,0,0,0"/>
                            </StackPanel>

                            <!-- Consentimiento de Trabajo (solo para edición) -->
                            <Border IsVisible="{Binding EsEdicion}"
                                    Background="#111827"
                                    CornerRadius="12"
                                    Padding="20"
                                    Margin="16,20,0,0">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="📝 Consentimiento de Trabajo"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,8"/>
                                    
                                    <!-- Estado del consentimiento -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding TrabajoSeleccionado.TieneConsentimiento, Converter={StaticResource BoolToTextConverter}, ConverterParameter='✅ Consentimiento firmado|⚠️ Sin consentimiento'}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock IsVisible="{Binding TrabajoSeleccionado.TieneConsentimiento}">
                                                <Run Text="Firmado el "/>
                                                <Run Text="{Binding TrabajoSeleccionado.Consentimiento.FechaFirma, StringFormat='{}{0:dd/MM/yyyy} a las {0:HH:mm}'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    IsVisible="{Binding TrabajoSeleccionado.TieneConsentimiento}">
                                            <Button Content="📄"
                                                    Classes="btn-secondary"
                                                    Command="{Binding AbrirConsentimientoTrabajoCommand}"
                                                    CommandParameter="{Binding TrabajoSeleccionado}"
                                                    ToolTip.Tip="Ver PDF"
                                                    Width="36"
                                                    Height="36"
                                                    Padding="0"
                                                    FontSize="18"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"/>
                                            <Button Content="💾"
                                                    Classes="btn-secondary"
                                                    Command="{Binding ExportarConsentimientoTrabajoCommand}"
                                                    CommandParameter="{Binding TrabajoSeleccionado}"
                                                    ToolTip.Tip="Exportar PDF"
                                                    Width="36"
                                                    Height="36"
                                                    Padding="0"
                                                    FontSize="18"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"/>
                                            <Button Content="📧"
                                                    Classes="btn-secondary"
                                                    Command="{Binding EnviarConsentimientoTrabajoPorCorreoCommand}"
                                                    CommandParameter="{Binding TrabajoSeleccionado}"
                                                    ToolTip.Tip="Enviar por correo"
                                                    Width="36"
                                                    Height="36"
                                                    Padding="0"
                                                    FontSize="18"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Botón para firmar si no tiene consentimiento -->
                                    <Button IsVisible="{Binding !TrabajoSeleccionado.TieneConsentimiento}"
                                            Classes="btn-primary"
                                            Command="{Binding FirmarConsentimientoTrabajoCommand}"
                                            CommandParameter="{Binding TrabajoSeleccionado}"
                                            HorizontalAlignment="Stretch"
                                            MinHeight="48"
                                            Padding="16,10"
                                            Margin="0,8,0,0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center">
                                        <TextBlock Text="📝 Firmar consentimiento de trabajo"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Fotos del trabajo (antes / después) -->
                            <Border IsVisible="{Binding EsEdicion}"
                                    Background="#020617"
                                    CornerRadius="12"
                                    Padding="20"
                                    Margin="16,16,0,0">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="📸 Fotos del trabajo"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Requiere RGPD y consentimiento de este trabajo. Si el cliente permite fotos, en mayores hace falta también el consentimiento de imágenes. Las fotos se pueden cambiar después de firmar desde esta misma ficha."
                                               FontSize="12"
                                               Opacity="0.7"
                                               TextWrapping="Wrap"/>

                                    <!-- Grid con fotos y botones -->
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16" RowDefinitions="Auto,Auto,Auto">
                                        <!-- Foto ANTES -->
                                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="8">
                                            <TextBlock Text="Foto ANTES"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.9"/>
                                            
                                            <!-- Preview de foto ANTES -->
                                            <Border Width="280"
                                                    Height="200"
                                                    Background="#111827"
                                                    CornerRadius="8"
                                                    BorderBrush="#374151"
                                                    BorderThickness="1"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding FotoAntesImagen}"
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                    <!-- Placeholder si no hay foto -->
                                                    <TextBlock Text="Sin foto"
                                                               FontSize="13"
                                                               Opacity="0.5"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding MuestraSinFotoAntes}"/>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- Botones para foto ANTES -->
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="➕ Añadir"
                                                        Classes="btn-secondary"
                                                        Command="{Binding TomarFotoAntesCommand}"
                                                        CommandParameter="{Binding TrabajoSeleccionado}"
                                                        IsEnabled="{Binding ClientePermiteFotosEnTrabajo}"
                                                        MinWidth="100"
                                                        Height="36"
                                                        Padding="12,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"/>
                                                <Button Content="👁️ Ver"
                                                        Classes="btn-secondary"
                                                        Command="{Binding VerFotoAntesCommand}"
                                                        CommandParameter="{Binding TrabajoSeleccionado}"
                                                        IsEnabled="{Binding TrabajoSeleccionado.FotoAntesPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        MinWidth="100"
                                                        Height="36"
                                                        Padding="12,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Foto DESPUÉS -->
                                        <StackPanel Grid.Column="1" Grid.Row="0" Spacing="8">
                                            <TextBlock Text="Foto DESPUÉS"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.9"/>
                                            
                                            <!-- Preview de foto DESPUÉS -->
                                            <Border Width="280"
                                                    Height="200"
                                                    Background="#111827"
                                                    CornerRadius="8"
                                                    BorderBrush="#374151"
                                                    BorderThickness="1"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding FotoDespuesImagen}"
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                    <!-- Placeholder si no hay foto -->
                                                    <TextBlock Text="Sin foto"
                                                               FontSize="13"
                                                               Opacity="0.5"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding MuestraSinFotoDespues}"/>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- Botones para foto DESPUÉS -->
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="➕ Añadir"
                                                        Classes="btn-secondary"
                                                        Command="{Binding TomarFotoDespuesCommand}"
                                                        CommandParameter="{Binding TrabajoSeleccionado}"
                                                        IsEnabled="{Binding ClientePermiteFotosEnTrabajo}"
                                                        MinWidth="100"
                                                        Height="36"
                                                        Padding="12,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"/>
                                                <Button Content="👁️ Ver"
                                                        Classes="btn-secondary"
                                                        Command="{Binding VerFotoDespuesCommand}"
                                                        CommandParameter="{Binding TrabajoSeleccionado}"
                                                        IsEnabled="{Binding TrabajoSeleccionado.FotoDespuesPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        MinWidth="100"
                                                        Height="36"
                                                        Padding="12,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Botón para abrir carpeta -->
                                    <Button Content="📂 Abrir carpeta de fotos"
                                            Classes="btn-secondary"
                                            Command="{Binding AbrirCarpetaFotosTrabajoCommand}"
                                            CommandParameter="{Binding TrabajoSeleccionado}"
                                            Height="40"
                                            HorizontalAlignment="Left"
                                            MinWidth="200"
                                            Padding="16,0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Mensaje de error -->
                            <Border IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="#3d2a2a"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,16,0,8">
                                <TextBlock Text="{Binding MensajeError}" 
                                           Foreground="#ef5350"
                                           TextWrapping="Wrap"/>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer botones -->
                    <Border Grid.Row="2"
                            Background="#111827"
                            Padding="28,20"
                            CornerRadius="0,0,18,18">
                        <Grid ColumnDefinitions="Auto,*">
                            <Button Grid.Column="0"
                                    Content="🗑️ Eliminar trabajo"
                                    Classes="btn-danger"
                                    Command="{Binding EliminarTrabajoCommand}"
                                    IsVisible="{Binding EsEdicion}"
                                    IsEnabled="{Binding TrabajoCamposPrincipalesHabilitados}"
                                    MinWidth="150"
                                    Height="42"
                                    Padding="12,0"
                                    HorizontalAlignment="Left"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="12">
                                <Button Content="Cancelar"
                                        Classes="btn-secondary"
                                        Command="{Binding CancelarEdicionCommand}"
                                        MinWidth="130"
                                        Height="42"
                                        Padding="12,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                                <Button Content="💾 Guardar"
                                        Classes="btn-primary"
                                        Command="{Binding GuardarTrabajoCommand}"
                                        IsEnabled="{Binding TrabajoCamposPrincipalesHabilitados}"
                                        MinWidth="130"
                                        Height="42"
                                        Padding="12,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        ToolTip.Tip="{Binding TrabajoFormularioBloqueadoPorConsentimiento, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Consentimiento firmado: no se puede guardar cambios del trabajo|Guardar trabajo'}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>
        
        <!-- Overlay de carga -->
        <Border Grid.ColumnSpan="2"
                IsVisible="{Binding Cargando}"
                Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Cargando..." Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Modal de firma de consentimientos -->
        <views:ConsentimientoFirmaView DataContext="{Binding ConsentimientoFirmaVM}"/>

        <!-- Modal de fotos de trabajo -->
        <views:FotoTrabajoView DataContext="{Binding FotoTrabajoVM}"/>
        
        <!-- Aviso de consentimiento pendiente (no bloqueante) -->
        <Border Grid.Row="1"
                IsVisible="{Binding MostrarAvisoConsentimiento}"
                Background="#2d3748"
                CornerRadius="8"
                Padding="20"
                Margin="30,10,30,10"
                BorderBrush="#4a5568"
                BorderThickness="2">
            <StackPanel Spacing="14">
                <StackPanel>
                    <TextBlock Text="{Binding MensajeAvisoConsentimiento}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Puedes firmarlo ahora o más tarde desde la lista de trabajos."
                               FontSize="12"
                               Opacity="0.7"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding FirmarConsentimientoTrabajoCommand}"
                            CommandParameter="{Binding TrabajoPendienteConsentimiento}"
                            Classes="btn-primary"
                            MinWidth="150"
                            MinHeight="44"
                            Padding="16,10"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">
                        <TextBlock Text="📝 Firmar ahora"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding CerrarAvisoConsentimientoCommand}"
                            Classes="btn-secondary"
                            MinWidth="120"
                            MinHeight="44"
                            Padding="16,10"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Content="Más tarde"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
    </Grid>

</UserControl>

