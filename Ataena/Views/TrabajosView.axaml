<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ataena.ViewModels"
             xmlns:models="using:Ataena.Models"
             xmlns:views="using:Ataena.Views"
             xmlns:converters="using:Ataena.Converters"
             x:Class="Ataena.Views.TrabajosView"
             x:DataType="vm:TrabajosViewModel"
             Loaded="OnLoaded">

    <UserControl.Styles>
        <!-- Tarjeta de trabajo (mismo estilo que clientes) -->
        <Style Selector="Border.trabajo-card">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2a2a3e"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.trabajo-card:pointerover">
            <Setter Property="Background" Value="#22223a"/>
            <Setter Property="BorderBrush" Value="#4c3d6e"/>
        </Style>

        <Style Selector="Border.chip">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- Formulario -->
        <Style Selector="Border.form-container">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25"/>
        </Style>
        
        <!-- Campo de formulario -->
        <Style Selector="TextBox.form-field">
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        
        <!-- Los estilos de botones están definidos globalmente en App.axaml -->
        
        <!-- Botón peligro -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="#f44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </UserControl.Styles>

    <Panel>
        <Grid RowDefinitions="*,Auto">
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA 0: LISTA DE TRABAJOS                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto,*,Auto" Margin="30">
            
            <!-- Cabecera -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="💼 Trabajos" FontSize="28" FontWeight="Bold"/>
                <TextBlock Opacity="0.6" Margin="0,5,0,0">
                    <Run Text="Total: "/>
                    <Run Text="{Binding TotalTrabajos}"/>
                    <Run Text=" trabajos"/>
                </TextBlock>
            </StackPanel>
            
            <!-- Barra de búsqueda y acciones -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <TextBox Grid.Column="0"
                         Text="{Binding TextoBusqueda}"
                         Watermark="🔍 Buscar por descripción, cliente, DNI, teléfono, zona..."
                         Margin="0,0,10,0"/>
                <Button Grid.Column="1"
                        Content="➕ Nuevo Trabajo"
                        Classes="btn-primary"
                        Command="{Binding NuevoTrabajoCommand}"/>
            </Grid>
            
            <!-- Lista de trabajos -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Trabajos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Trabajo">
                            <Border Classes="trabajo-card"
                                    PointerPressed="OnTrabajoClick"
                                    Tag="{Binding}">
                                <Grid ColumnDefinitions="Auto,*,Auto">

                                    <!-- Barra de estado (consentimiento) -->
                                    <Grid Grid.Column="0"
                                          Width="4"
                                          Margin="0,2,14,2"
                                          VerticalAlignment="Stretch"
                                          MinHeight="48">
                                        <Border CornerRadius="2"
                                                IsVisible="{Binding TieneConsentimiento}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#34d399" Offset="0"/>
                                                    <GradientStop Color="#059669" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Border CornerRadius="2"
                                                IsVisible="{Binding !TieneConsentimiento}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#f87171" Offset="0"/>
                                                    <GradientStop Color="#dc2626" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Grid>

                                    <!-- Info principal -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                        <TextBlock Text="{Binding Descripcion}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#f1f5f9"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <WrapPanel Orientation="Horizontal">
                                            <Border Classes="chip"
                                                    Background="#6366f122"
                                                    BorderBrush="#6366f155"
                                                    BorderThickness="1"
                                                    Margin="0,0,6,4">
                                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#a5b4fc">
                                                    <Run Text="{Binding IconoTipo}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Tipo}"/>
                                                </TextBlock>
                                            </Border>
                                            <Border Classes="chip"
                                                    IsVisible="{Binding !TieneConsentimiento}"
                                                    Background="#ef444422"
                                                    BorderBrush="#ef444455"
                                                    BorderThickness="1"
                                                    Margin="0,0,6,4">
                                                <TextBlock Text="Sin consentimiento"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#fca5a5"/>
                                            </Border>
                                            <Border Classes="chip"
                                                    IsVisible="{Binding TieneConsentimiento}"
                                                    Background="#10b98122"
                                                    BorderBrush="#10b98155"
                                                    BorderThickness="1"
                                                    Margin="0,0,6,4">
                                                <TextBlock Text="Consentimiento"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#6ee7b7"/>
                                            </Border>
                                            <Border Classes="chip"
                                                    IsVisible="{Binding Colores}"
                                                    Background="#8b5cf622"
                                                    BorderBrush="#8b5cf655"
                                                    BorderThickness="1"
                                                    Margin="0,0,6,4">
                                                <TextBlock Text="Color"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#c4b5fd"/>
                                            </Border>
                                        </WrapPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="14">
                                            <TextBlock FontSize="12" Foreground="#94a3b8">
                                                <Run Text="👤 "/>
                                                <Run Text="{Binding Cliente.NombreCompleto}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#94a3b8"
                                                       IsVisible="{Binding Cliente.Telefono, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Run Text="📞 "/>
                                                <Run Text="{Binding Cliente.Telefono}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#94a3b8"
                                                       IsVisible="{Binding ZonaCuerpo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Run Text="📍 "/>
                                                <Run Text="{Binding ZonaCuerpo}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Fecha -->
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding FechaCreacion, StringFormat='dd/MM/yyyy'}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#cbd5e1"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Mensaje de error -->
            <Border Grid.Row="3"
                    IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="#3d2a2a"
                    CornerRadius="6"
                    Padding="15"
                    Margin="0,10,0,0">
                <TextBlock Text="{Binding MensajeError}" Foreground="#ef5350"/>
            </Border>
            
        </Grid>
        
        <!-- Overlay de carga -->
        <Border Grid.ColumnSpan="2"
                IsVisible="{Binding Cargando}"
                Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Cargando..." Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Modal de firma de consentimientos -->
        <views:ConsentimientoFirmaView DataContext="{Binding ConsentimientoFirmaVM}"/>

        <!-- Modal de fotos de trabajo -->
        <views:FotoTrabajoView DataContext="{Binding FotoTrabajoVM}"/>
        
        <!-- Aviso de consentimiento pendiente (no bloqueante) -->
        <Border Grid.Row="1"
                IsVisible="{Binding MostrarAvisoConsentimiento}"
                Background="#2d3748"
                CornerRadius="8"
                Padding="20"
                Margin="30,10,30,10"
                BorderBrush="#4a5568"
                BorderThickness="2">
            <StackPanel Spacing="14">
                <StackPanel>
                    <TextBlock Text="{Binding MensajeAvisoConsentimiento}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Puedes firmarlo ahora o más tarde desde la lista de trabajos."
                               FontSize="12"
                               Opacity="0.7"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding FirmarConsentimientoTrabajoCommand}"
                            CommandParameter="{Binding TrabajoPendienteConsentimiento}"
                            Classes="btn-primary"
                            MinWidth="150"
                            MinHeight="44"
                            Padding="16,10"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">
                        <TextBlock Text="📝 Firmar ahora"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding CerrarAvisoConsentimientoCommand}"
                            Classes="btn-secondary"
                            MinWidth="120"
                            MinHeight="44"
                            Padding="16,10"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Content="Más tarde"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MODAL: FORMULARIO (capa superior a toda la vista de trabajos)   -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="FormularioTrabajoOverlay"
                ZIndex="500"
                IsVisible="{Binding MostrarFormulario}"
                Background="#B0000000"
                Padding="40"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                PointerPressed="OnFormularioTrabajoOverlayPointerPressed">
            <!-- Modal centrado con glow suave (altura completa para permitir scroll interno) -->
            <Border x:Name="FormularioTrabajoPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="540"
                    MaxWidth="660"
                    MaxHeight="800"
                    Background="#020617"
                    CornerRadius="18"
                    BoxShadow="0 0 80 0 #50d946ef, 0 0 120 0 #40ec4899"
                    Focusable="False"
                    IsTabStop="False">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Cabecera del modal -->
                    <Border Grid.Row="0"
                            Background="#111827"
                            Padding="28,22"
                            CornerRadius="18,18,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TituloFormulario}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    FontSize="16"
                                    Width="36"
                                    Height="36"
                                    Background="Transparent"
                                    Foreground="#9ca3af"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Command="{Binding CancelarEdicionCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Contenido scrollable -->
                    <ScrollViewer x:Name="FormularioTrabajoScrollViewer"
                                  Grid.Row="1"
                                  Padding="28,24,40,24"
                                  VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Focusable="True"
                                  IsTabStop="True">
                        <!-- Margen inferior generoso para que el último campo no quede oculto tras el footer -->
                        <StackPanel Margin="0,0,0,80">

                            <!-- Aviso si tiene consentimiento firmado (solo en edición) -->
                            <Border IsVisible="{Binding MostrarAvisoNoModificable}"
                                    Background="#3d2a2a"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,20"
                                    BorderBrush="#ef5350"
                                    BorderThickness="2">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="⚠️ Consentimiento de trabajo firmado"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="#ef5350"/>
                                    <TextBlock Text="Cliente, tipo y descripción ya no se pueden cambiar (van en el consentimiento firmado). Sí puedes editar las notas internas, ver, renovar o borrar el consentimiento y gestionar las fotos del trabajo."
                                               FontSize="12"
                                               Foreground="#ffcdd2"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Cliente / tipo / descripción (consentimiento). Sin IsEnabled en el panel: evita que el ComboBox vacíe ClienteSeleccionado al deshabilitar. -->
                            <StackPanel>

                            <!-- Cliente (búsqueda + desplegable, o fijo si viene de ficha/agenda) -->
                            <TextBlock Text="Cliente *" Opacity="0.7" Margin="0,0,0,5"/>
                            <Border IsVisible="{Binding ClienteBloqueadoEnFormulario}"
                                    Background="#111827"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding ClienteSeleccionado.NombreCompleto}"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ClienteSeleccionado.Telefono}"
                                               FontSize="12"
                                               Opacity="0.7"/>
                                    <TextBlock Text="Cliente fijado — no se puede cambiar en este flujo"
                                               FontSize="11"
                                               Opacity="0.5"
                                               Foreground="#94a3b8"/>
                                </StackPanel>
                            </Border>
                            <StackPanel IsVisible="{Binding !ClienteBloqueadoEnFormulario}">
                            <TextBox Name="ClienteBusquedaTrabajoTextBox"
                                     Text="{Binding TextoBusquedaClienteFormulario, Mode=TwoWay}"
                                     Watermark="Buscar por nombre o teléfono…"
                                     Classes="form-field"
                                     Margin="0,0,0,8"
                                     IsEnabled="{Binding ClienteFormularioEditable}"
                                     TextChanged="OnClienteBusquedaTrabajoTextChanged"/>
                            <ComboBox Name="ClienteTrabajoComboBox"
                                      ItemsSource="{Binding ClientesFiltradosFormulario}"
                                      SelectedItem="{Binding ClienteSeleccionado}"
                                      IsEnabled="{Binding ClienteFormularioEditable}"
                                      MinWidth="260"
                                      DropDownOpened="OnClienteTrabajoComboDropDownOpened">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding NombreCompleto}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Telefono}"
                                                       FontSize="11"
                                                       Opacity="0.7"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            </StackPanel>

                            <!-- Tipo -->
                            <TextBlock Text="Tipo *" Opacity="0.7" Margin="16,16,0,5"/>
                            <ComboBox SelectedItem="{Binding TipoTrabajo}"
                                      IsEnabled="{Binding TrabajoCamposPrincipalesHabilitados}"
                                      Height="40">
                                <ComboBox.Items>
                                    <x:Static Member="models:TipoTrabajo.Tatuaje"/>
                                    <x:Static Member="models:TipoTrabajo.Piercing"/>
                                </ComboBox.Items>
                            </ComboBox>

                            <!-- Descripción -->
                            <TextBlock Text="Descripción * (aparece en el consentimiento)" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Text="{Binding Descripcion}"
                                     Watermark="Ej.: tigre en el cuello, piercing ombligo…"
                                     IsEnabled="{Binding TrabajoCamposPrincipalesHabilitados}"
                                     Classes="form-field"/>
                            </StackPanel>

                            <!-- Notas internas: editables aunque el consentimiento esté firmado -->
                            <TextBlock Text="Notas (solo estudio, no en el consentimiento)" Opacity="0.7" Margin="0,16,0,5"/>
                            <TextBox Text="{Binding Notas}"
                                     Watermark="Notas internas…"
                                     AcceptsReturn="True"
                                     Height="80"
                                     TextWrapping="Wrap"
                                     Classes="form-field"/>

                            <!-- Consentimiento de Trabajo (solo para edición) -->
                            <Border IsVisible="{Binding EsEdicion}"
                                    Background="#111827"
                                    CornerRadius="12"
                                    Padding="20"
                                    Margin="16,20,0,0">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="📝 Consentimiento de Trabajo"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,8"/>
                                    
                                    <!-- Estado del consentimiento -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding TrabajoSeleccionado.TieneConsentimiento, Converter={StaticResource BoolToTextConverter}, ConverterParameter='✅ Consentimiento firmado|⚠️ Sin consentimiento'}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock IsVisible="{Binding TrabajoSeleccionado.TieneConsentimiento}">
                                                <Run Text="Firmado el "/>
                                                <Run Text="{Binding TrabajoSeleccionado.Consentimiento.FechaFirma, StringFormat='{}{0:dd/MM/yyyy} a las {0:HH:mm}'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    IsVisible="{Binding TrabajoSeleccionado.TieneConsentimiento}">
                                            <Button Classes="btn-secondary"
                                                    MinWidth="64"
                                                    Height="34"
                                                    Padding="8,0"
                                                    Command="{Binding AbrirConsentimientoTrabajoCommand}"
                                                    CommandParameter="{Binding TrabajoSeleccionado}"
                                                    ToolTip.Tip="Abrir PDF">
                                                <TextBlock Text="Ver" FontSize="12"/>
                                            </Button>
                                            <Button Classes="btn-secondary"
                                                    MinWidth="76"
                                                    Height="34"
                                                    Padding="8,0"
                                                    Command="{Binding RenovarConsentimientoTrabajoCommand}"
                                                    CommandParameter="{Binding TrabajoSeleccionado}"
                                                    ToolTip.Tip="Firmar de nuevo (sustituye al anterior)">
                                                <TextBlock Text="Renovar" FontSize="12"/>
                                            </Button>
                                            <Button Classes="btn-danger"
                                                    MinWidth="68"
                                                    Height="34"
                                                    Padding="8,0"
                                                    Command="{Binding EliminarConsentimientoTrabajoCommand}"
                                                    CommandParameter="{Binding TrabajoSeleccionado}"
                                                    ToolTip.Tip="Eliminar consentimiento y PDF">
                                                <TextBlock Text="Borrar" FontSize="12"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Botón para firmar si no tiene consentimiento -->
                                    <Button IsVisible="{Binding !TrabajoSeleccionado.TieneConsentimiento}"
                                            Classes="btn-primary"
                                            Command="{Binding FirmarConsentimientoTrabajoCommand}"
                                            CommandParameter="{Binding TrabajoSeleccionado}"
                                            HorizontalAlignment="Stretch"
                                            MinHeight="48"
                                            Padding="16,10"
                                            Margin="0,8,0,0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center">
                                        <TextBlock Text="📝 Firmar consentimiento de trabajo"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Fotos del trabajo (antes / después) -->
                            <Border IsVisible="{Binding EsEdicion}"
                                    Background="#020617"
                                    CornerRadius="12"
                                    Padding="20"
                                    Margin="16,16,0,0">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="📸 Fotos del trabajo"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Requiere RGPD y consentimiento de este trabajo. Si el cliente permite fotos, en mayores hace falta también el consentimiento de imágenes. Las fotos se pueden cambiar después de firmar desde esta misma ficha."
                                               FontSize="12"
                                               Opacity="0.7"
                                               TextWrapping="Wrap"/>

                                    <!-- Grid con fotos y botones -->
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16" RowDefinitions="Auto,Auto,Auto">
                                        <!-- Foto ANTES -->
                                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="8">
                                            <TextBlock Text="Foto ANTES"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.9"/>
                                            
                                            <!-- Preview de foto ANTES -->
                                            <Border Width="280"
                                                    Height="200"
                                                    Background="#111827"
                                                    CornerRadius="8"
                                                    BorderBrush="#374151"
                                                    BorderThickness="1"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding FotoAntesImagen}"
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                    <!-- Placeholder si no hay foto -->
                                                    <TextBlock Text="Sin foto"
                                                               FontSize="13"
                                                               Opacity="0.5"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding MuestraSinFotoAntes}"/>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- Botones para foto ANTES -->
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="➕ Añadir"
                                                        Classes="btn-secondary"
                                                        Command="{Binding TomarFotoAntesCommand}"
                                                        CommandParameter="{Binding TrabajoSeleccionado}"
                                                        IsEnabled="{Binding ClientePermiteFotosEnTrabajo}"
                                                        MinWidth="100"
                                                        Height="36"
                                                        Padding="12,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"/>
                                                <Button Content="👁️ Ver"
                                                        Classes="btn-secondary"
                                                        Command="{Binding VerFotoAntesCommand}"
                                                        CommandParameter="{Binding TrabajoSeleccionado}"
                                                        IsEnabled="{Binding TrabajoSeleccionado.FotoAntesPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        MinWidth="100"
                                                        Height="36"
                                                        Padding="12,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Foto DESPUÉS -->
                                        <StackPanel Grid.Column="1" Grid.Row="0" Spacing="8">
                                            <TextBlock Text="Foto DESPUÉS"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.9"/>
                                            
                                            <!-- Preview de foto DESPUÉS -->
                                            <Border Width="280"
                                                    Height="200"
                                                    Background="#111827"
                                                    CornerRadius="8"
                                                    BorderBrush="#374151"
                                                    BorderThickness="1"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding FotoDespuesImagen}"
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                    <!-- Placeholder si no hay foto -->
                                                    <TextBlock Text="Sin foto"
                                                               FontSize="13"
                                                               Opacity="0.5"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding MuestraSinFotoDespues}"/>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- Botones para foto DESPUÉS -->
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="➕ Añadir"
                                                        Classes="btn-secondary"
                                                        Command="{Binding TomarFotoDespuesCommand}"
                                                        CommandParameter="{Binding TrabajoSeleccionado}"
                                                        IsEnabled="{Binding ClientePermiteFotosEnTrabajo}"
                                                        MinWidth="100"
                                                        Height="36"
                                                        Padding="12,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"/>
                                                <Button Content="👁️ Ver"
                                                        Classes="btn-secondary"
                                                        Command="{Binding VerFotoDespuesCommand}"
                                                        CommandParameter="{Binding TrabajoSeleccionado}"
                                                        IsEnabled="{Binding TrabajoSeleccionado.FotoDespuesPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        MinWidth="100"
                                                        Height="36"
                                                        Padding="12,0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Botón para abrir carpeta -->
                                    <Button Content="📂 Abrir carpeta de fotos"
                                            Classes="btn-secondary"
                                            Command="{Binding AbrirCarpetaFotosTrabajoCommand}"
                                            CommandParameter="{Binding TrabajoSeleccionado}"
                                            Height="40"
                                            HorizontalAlignment="Left"
                                            MinWidth="200"
                                            Padding="16,0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Mensaje de error -->
                            <Border IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="#3d2a2a"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,16,0,8">
                                <TextBlock Text="{Binding MensajeError}" 
                                           Foreground="#ef5350"
                                           TextWrapping="Wrap"/>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer botones -->
                    <Border Grid.Row="2"
                            Background="#111827"
                            Padding="28,20"
                            CornerRadius="0,0,18,18">
                        <Grid ColumnDefinitions="Auto,*">
                            <Button Grid.Column="0"
                                    Content="🗑️ Eliminar trabajo"
                                    Classes="btn-danger"
                                    Command="{Binding EliminarTrabajoCommand}"
                                    IsVisible="{Binding EsEdicion}"
                                    IsEnabled="{Binding PuedeEliminarTrabajo}"
                                    ToolTip.Tip="{Binding TooltipEliminarTrabajo}"
                                    MinWidth="150"
                                    Height="42"
                                    Padding="12,0"
                                    HorizontalAlignment="Left"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="12">
                                <Button Content="Cerrar"
                                        Classes="btn-secondary"
                                        Command="{Binding CancelarEdicionCommand}"
                                        ToolTip.Tip="Cerrar sin guardar cambios pendientes (usa Guardar si has editado algo)"
                                        MinWidth="130"
                                        Height="42"
                                        Padding="12,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                                <Button Content="💾 Guardar"
                                        Classes="btn-primary"
                                        Command="{Binding GuardarTrabajoCommand}"
                                        IsEnabled="{Binding PuedeGuardarTrabajoFormulario}"
                                        MinWidth="130"
                                        Height="42"
                                        Padding="12,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        ToolTip.Tip="{Binding TrabajoFormularioBloqueadoPorConsentimiento, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Guardar solo las notas internas|Guardar trabajo'}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>

    </Panel>

</UserControl>

