<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:InkStudio"
             xmlns:converters="using:InkStudio.Converters"
             x:Class="InkStudio.App"
             RequestedThemeVariant="Dark">

    <!-- Recursos globales (conversores, colores) -->
    <Application.Resources>
        <!-- Conversores -->
        <converters:EqualConverter x:Key="EqualConverter"/>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter"/>
        <converters:EstadoCitaToColorConverter x:Key="EstadoCitaToColorConverter"/>
        <converters:BoolToTextConverter x:Key="BoolToTextConverter"/>
        <converters:BoolToCursorConverter x:Key="BoolToCursorConverter"/>

        <!-- Paleta base oscura moderna (morado / naranja) -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#020617"/>
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="#020617"/>
        <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#020617"/>
        <SolidColorBrush x:Key="AppBorderBrush" Color="#1f2937"/>

        <!-- Acentos morado/naranja -->
        <SolidColorBrush x:Key="AppAccentBrush" Color="#a855f7"/> <!-- morado -->
        <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#f97316"/> <!-- naranja -->
        <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#e5e7eb"/>
        <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#9ca3af"/>
        <SolidColorBrush x:Key="AppErrorBrush" Color="#ef4444"/>

        <!-- Degradado principal morado/naranja -->
        <LinearGradientBrush x:Key="AppAccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#a855f7" Offset="0.0"/>
            <GradientStop Color="#f97316" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Degradado para botones primarios (verde moderno con zonas muy contrastadas) -->
        <LinearGradientBrush x:Key="AppButtonPrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6ee7b7" Offset="0.0"/> <!-- Verde muy claro/brillante (esmeralda claro) -->
            <GradientStop Color="#34d399" Offset="0.2"/> <!-- Verde claro -->
            <GradientStop Color="#10b981" Offset="0.4"/> <!-- Verde medio-claro -->
            <GradientStop Color="#059669" Offset="0.6"/> <!-- Verde medio -->
            <GradientStop Color="#047857" Offset="0.8"/> <!-- Verde medio-oscuro -->
            <GradientStop Color="#065f46" Offset="1.0"/> <!-- Verde oscuro -->
        </LinearGradientBrush>

        <!-- Degradado para hover de botones primarios (más intenso y oscuro) -->
        <LinearGradientBrush x:Key="AppButtonPrimaryHoverGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#34d399" Offset="0.0"/> <!-- Verde claro -->
            <GradientStop Color="#10b981" Offset="0.25"/> <!-- Verde medio-claro -->
            <GradientStop Color="#059669" Offset="0.5"/> <!-- Verde medio -->
            <GradientStop Color="#047857" Offset="0.75"/> <!-- Verde medio-oscuro -->
            <GradientStop Color="#065f46" Offset="1.0"/> <!-- Verde oscuro -->
        </LinearGradientBrush>

        <!-- Degradado para botones secundarios -->
        <LinearGradientBrush x:Key="AppButtonSecondaryGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1f2937" Offset="0.0"/>
            <GradientStop Color="#374151" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Glow amplio y difuminado para modales (radial con degradado morado→naranja) -->
        <RadialGradientBrush x:Key="AppModalGlowBrush"
                             Center="0.5,0.5"
                             GradientOrigin="0.5,0.5"
                             RadiusX="120%"
                             RadiusY="120%">
            <!-- Centro transparente (donde va el modal) -->
            <GradientStop Color="#00000000" Offset="0.0"/>
            <!-- Empieza transparente pero cerca del borde -->
            <GradientStop Color="#00000000" Offset="0.6"/>
            <!-- Empieza morado visible -->
            <GradientStop Color="#50a855f7" Offset="0.75"/>
            <!-- Morado más intenso -->
            <GradientStop Color="#80a855f7" Offset="0.85"/>
            <!-- Transición a naranja -->
            <GradientStop Color="#70f97316" Offset="0.92"/>
            <!-- Naranja en los bordes -->
            <GradientStop Color="#50f97316" Offset="0.97"/>
            <!-- Exterior transparente para difuminar -->
            <GradientStop Color="#00000000" Offset="1.0"/>
        </RadialGradientBrush>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />

        <!-- Estilos globales de controles básicos -->
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
        </Style>

        <Style Selector="ComboBox:pointerover">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        </Style>

        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        </Style>

        <!-- Scrollbars modernos y discretos -->
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
        </Style>

        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="#64748b"/>
        </Style>

        <Style Selector="ScrollBar:pointerover /template/ Thumb">
            <Setter Property="Background" Value="#94a3b8"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ESTILOS MODERNOS DE BOTONES CON DEGRADADOS                      -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <!-- Botón Primario (con degradado verde moderno) -->
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource AppButtonPrimaryGradientBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.btn-primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppButtonPrimaryHoverGradientBrush}"/>
        </Style>

        <Style Selector="Button.btn-primary:pressed">
            <Setter Property="Background" Value="{DynamicResource AppButtonPrimaryHoverGradientBrush}"/>
        </Style>

        <!-- Botón Secundario (estilo moderno con degradado sutil) -->
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource AppButtonSecondaryGradientBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.btn-secondary:pointerover">
            <Setter Property="Background" Value="#4b5563"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.btn-secondary:pressed">
            <Setter Property="Background" Value="#374151"/>
        </Style>

        <!-- Botón Peligro (rojo con degradado) -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#dc2626" Offset="0.0"/>
                    <GradientStop Color="#b91c1c" Offset="1.0"/>
                </LinearGradientBrush>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.btn-danger:pointerover">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#b91c1c" Offset="0.0"/>
                    <GradientStop Color="#991b1b" Offset="1.0"/>
                </LinearGradientBrush>
            </Setter>
        </Style>

        <Style Selector="Button.btn-danger:pressed">
            <!-- Efecto de presión -->
        </Style>

        <!-- Botón Cerrar (X) - estilo moderno -->
        <Style Selector="Button.btn-close">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.btn-close:pointerover">
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.btn-close:pressed">
            <Setter Property="Background" Value="#4b5563"/>
        </Style>

        <!-- Botones de Navegación (sidebar) -->
        <Style Selector="Button.nav-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.nav-btn:pointerover">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1f2937" Offset="0.0"/>
                    <GradientStop Color="#2a2a3e" Offset="1.0"/>
                </LinearGradientBrush>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.nav-btn:pressed">
            <Setter Property="Background" Value="#374151"/>
        </Style>

        <!-- Botones de Acción Rápida (Dashboard) -->
        <Style Selector="Button.quick-action">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1f2937" Offset="0.0"/>
                    <GradientStop Color="#111827" Offset="1.0"/>
                </LinearGradientBrush>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,18"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.quick-action:pointerover">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#374151" Offset="0.0"/>
                    <GradientStop Color="#1f2937" Offset="1.0"/>
                </LinearGradientBrush>
            </Setter>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        </Style>

        <Style Selector="Button.quick-action:pressed">
            <Setter Property="Background" Value="#374151"/>
        </Style>
    </Application.Styles>
    
</Application>
