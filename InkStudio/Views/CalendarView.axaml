<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InkStudio.ViewModels"
             xmlns:models="using:InkStudio.Models"
             xmlns:si="clr-namespace:SatialInterfaces.Controls.Calendar;assembly=CalendarControl"
             x:Class="InkStudio.Views.CalendarView"
             x:DataType="vm:CalendarViewModel">

    <Grid RowDefinitions="Auto,*" Margin="10">
        <!-- Controles de navegación -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
            <Button Grid.Column="0" 
                    Content="◀ Mes Anterior" 
                    Command="{Binding MesAnteriorCommand}"
                    HorizontalAlignment="Left"/>
            
            <Button Grid.Column="1" 
                    Content="Hoy" 
                    Command="{Binding IrAMesActualCommand}"
                    HorizontalAlignment="Center"
                    Margin="10,0"/>
            
            <Button Grid.Column="2" 
                    Content="Mes Siguiente ▶" 
                    Command="{Binding MesSiguienteCommand}"
                    HorizontalAlignment="Right"/>
        </Grid>

        <!-- CalendarControl con ItemTemplate para mostrar las citas -->
        <si:CalendarControl Grid.Row="1"
                           Items="{Binding Citas}">
            <si:CalendarControl.ItemTemplate>
                <DataTemplate x:DataType="models:Cita">
                    <si:AppointmentControl Begin="{Binding FechaHoraInicio}" 
                                          End="{Binding FechaHoraFin}" 
                                          Text="{Binding Descripcion, TargetNullValue='Sin descripción'}" />
                </DataTemplate>
            </si:CalendarControl.ItemTemplate>
        </si:CalendarControl>
    </Grid>

</UserControl>
