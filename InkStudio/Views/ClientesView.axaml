<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InkStudio.ViewModels"
             xmlns:models="using:InkStudio.Models"
             xmlns:views="using:InkStudio.Views"
             x:Class="InkStudio.Views.ClientesView"
             x:DataType="vm:ClientesViewModel"
             Loaded="OnLoaded">

    <UserControl.Styles>
        <!-- Fila de cliente (estilo lista) -->
        <Style Selector="Border.cliente-card">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#272738"/>
        </Style>
        <Style Selector="Border.cliente-card:pointerover">
            <Setter Property="Background" Value="#202032"/>
        </Style>
        
        <!-- Formulario -->
        <Style Selector="Border.form-container">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25"/>
        </Style>
        
        <!-- Campo de formulario -->
        <Style Selector="TextBox.form-field">
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        
        <!-- Los estilos de botones están definidos globalmente en App.axaml -->
        
        <!-- Botón peligro -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="#f44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA 0: LISTA DE CLIENTES                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*,Auto" Margin="30">
            
            <!-- Cabecera -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="👥 Clientes" FontSize="28" FontWeight="Bold"/>
                <TextBlock Opacity="0.6" Margin="0,5,0,0">
                    <Run Text="Total: "/>
                    <Run Text="{Binding TotalClientes}"/>
                    <Run Text=" clientes"/>
                </TextBlock>
            </StackPanel>
            
            <!-- Barra de búsqueda y acciones -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,20">
                <TextBox Grid.Column="0"
                         Text="{Binding TextoBusqueda}"
                         Watermark="🔍 Buscar por nombre, teléfono o email..."
                         Margin="0,0,10,0"/>
                <Button Grid.Column="1"
                        Content="Buscar"
                        Command="{Binding BuscarCommand}"
                        Margin="0,0,10,0"/>
                <Button Grid.Column="2"
                        Content="⚠️ Sin RGPD"
                        Classes="btn-secondary"
                        Command="{Binding FiltrarSinConsentimientoCommand}"
                        ToolTip.Tip="Mostrar solo clientes sin consentimiento RGPD firmado"
                        Margin="0,0,10,0"/>
                <Button Grid.Column="3"
                        Content="➕ Nuevo Cliente"
                        Classes="btn-primary"
                        Command="{Binding NuevoClienteCommand}"/>
            </Grid>
            
            <!-- Lista de clientes -->
            <ScrollViewer Grid.Row="2">
                <ItemsControl ItemsSource="{Binding Clientes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Cliente">
                            <Border Classes="cliente-card"
                                    PointerPressed="OnClienteClick"
                                    Tag="{Binding}">
                                <Grid ColumnDefinitions="*,Auto">
                                    
                                    <!-- Info -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding NombreCompleto}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"/>
                                            <!-- Indicador de consentimiento RGPD -->
                                            <Border Grid.Column="1"
                                                    IsVisible="{Binding !TieneConsentimientoRGPD}"
                                                    Background="#ef5350"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⚠️ Sin RGPD"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                            <Border Grid.Column="1"
                                                    IsVisible="{Binding TieneConsentimientoRGPD}"
                                                    Background="#10b981"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="✅ RGPD"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="15" Opacity="0.7">
                                            <TextBlock Text="{Binding Telefono}"/>
                                            <TextBlock Text="{Binding Email}" 
                                                       IsVisible="{Binding Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <TextBlock Text="{Binding Dni}" 
                                                       IsVisible="{Binding Dni, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding FechaNacimientoConEdad}"
                                                   FontSize="12"
                                                   Opacity="0.6"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Sin botones de acción: solo fila clicable -->
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Mensaje de error -->
            <Border Grid.Row="3"
                    IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="#3d2a2a"
                    CornerRadius="6"
                    Padding="15"
                    Margin="0,10,0,0">
                <TextBlock Text="{Binding MensajeError}" Foreground="#ef5350"/>
            </Border>
            
        </Grid>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MODAL: FORMULARIO DE CREACIÓN/EDICIÓN DE CLIENTE               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Grid.ColumnSpan="1"
                IsVisible="{Binding MostrarFormulario}"
                Background="#B0000000"
                Padding="40">
            <!-- Modal centrado con glow suave -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="540"
                    MaxWidth="660"
                    MaxHeight="800"
                    Background="#020617"
                    CornerRadius="18"
                    BoxShadow="0 0 80 0 #50d946ef, 0 0 120 0 #40ec4899">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Cabecera del modal -->
                    <Border Grid.Row="0"
                            Background="#111827"
                            Padding="28,22"
                            CornerRadius="18,18,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TituloFormulario}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    FontSize="16"
                                    Width="36"
                                    Height="36"
                                    Background="Transparent"
                                    Foreground="#9ca3af"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Command="{Binding CancelarEdicionCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Contenido scrollable -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="28,24,40,24"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <!-- Margen inferior generoso para que los últimos campos (checkboxes) no queden ocultos tras el footer -->
                        <StackPanel Margin="0,0,0,80">
                            <!-- Nombre -->
                            <TextBlock Text="Nombre *" Opacity="0.7" Margin="0,0,0,5"/>
                            <TextBox Classes="form-field"
                                     Text="{Binding Nombre}"
                                     Watermark="Nombre"/>

                            <!-- Apellidos -->
                            <TextBlock Text="Apellidos" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Classes="form-field"
                                     Text="{Binding Apellidos}"
                                     Watermark="Apellidos"/>

                            <!-- Teléfono -->
                            <TextBlock Text="Teléfono *" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Classes="form-field"
                                     Text="{Binding Telefono}"
                                     Watermark="612 345 678"/>

                            <!-- Email -->
                            <TextBlock Text="Email" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Classes="form-field"
                                     Text="{Binding Email}"
                                     Watermark="cliente@email.com"/>

                            <!-- DNI -->
                            <TextBlock Text="DNI" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Classes="form-field"
                                     Text="{Binding Dni}"
                                     Watermark="12345678A"/>

                            <!-- Fecha nacimiento -->
                            <TextBlock Text="Fecha de nacimiento" Opacity="0.7" Margin="16,16,0,5"/>
                            <DatePicker SelectedDate="{Binding FechaNacimiento}"
                                        Classes="form-field"
                                        Margin="0,0,0,15"
                                        HorizontalAlignment="Stretch"/>

                            <!-- Alergias -->
                            <TextBlock Text="Alergias (importante para tintas)" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Classes="form-field"
                                     Text="{Binding Alergias}"
                                     Watermark="Ninguna conocida"
                                     AcceptsReturn="True"
                                     Height="60"
                                     TextWrapping="Wrap"/>

                            <!-- Notas -->
                            <TextBlock Text="Notas" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Classes="form-field"
                                     Text="{Binding Notas}"
                                     Watermark="Notas adicionales..."
                                     AcceptsReturn="True"
                                     Height="80"
                                     TextWrapping="Wrap"/>

                            <!-- Consentimiento RGPD (solo para nuevos clientes) -->
                            <CheckBox IsVisible="{Binding !EsEdicion}"
                                      IsChecked="{Binding FirmarConsentimientoRGPD}"
                                      Content="📝 Firmar consentimiento RGPD (opcional)"
                                      Margin="16,20,0,8"
                                      FontSize="13"
                                      FontWeight="SemiBold"/>
                            
                            <!-- Consentimiento de imágenes (solo para nuevos clientes) -->
                            <CheckBox IsVisible="{Binding !EsEdicion}"
                                      IsChecked="{Binding SolicitarConsentimientoImagenes}"
                                      Content="📸 Solicitar consentimiento de uso de imágenes (opcional)"
                                      Margin="16,8,0,20"
                                      FontSize="13"/>

                            <!-- Mensaje de error -->
                            <Border IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="#3d2a2a"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,0,0,15">
                                <TextBlock Text="{Binding MensajeError}" 
                                           Foreground="#ef5350"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer botones -->
                    <Border Grid.Row="2"
                            Background="#111827"
                            Padding="28,20"
                            CornerRadius="0,0,18,18">
                        <Grid ColumnDefinitions="Auto,*">
                            <Button Grid.Column="0"
                                    Content="🗑️ Eliminar cliente"
                                    Classes="btn-danger"
                                    Command="{Binding EliminarClienteCommand}"
                                    IsVisible="{Binding EsEdicion}"
                                    MinWidth="150"
                                    Height="42"
                                    Padding="12,0"
                                    HorizontalAlignment="Left"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="12">
                                <Button Content="Cancelar"
                                        Classes="btn-secondary"
                                        Command="{Binding CancelarEdicionCommand}"
                                        MinWidth="130"
                                        Height="42"
                                        Padding="12,0"/>
                                <Button Content="💾 Guardar"
                                        Classes="btn-primary"
                                        Command="{Binding GuardarClienteCommand}"
                                        MinWidth="130"
                                        Height="42"
                                        Padding="12,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>
        
        <!-- Overlay de carga -->
        <Border Grid.ColumnSpan="2"
                IsVisible="{Binding Cargando}"
                Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Cargando..." Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MODAL: FICHA DEL CLIENTE                                         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Grid.ColumnSpan="1"
                IsVisible="{Binding MostrarFicha}"
                Background="#B0000000"
                Padding="40">
            <!-- Modal centrado con glow suave (altura completa para permitir scroll interno) -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    MinWidth="700"
                    MaxWidth="900"
                    Background="#020617"
                    CornerRadius="18"
                    BoxShadow="0 0 80 0 #50d946ef, 0 0 120 0 #40ec4899">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Cabecera del modal -->
                    <Border Grid.Row="0"
                            Background="#111827"
                            Padding="28,22"
                            CornerRadius="18,18,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding ClienteSeleccionado.NombreCompleto, TargetNullValue='Ficha del Cliente'}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ClienteSeleccionado.Telefono}"
                                           FontSize="13"
                                           Opacity="0.7"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="✏️ Editar"
                                        Classes="btn-secondary"
                                        Command="{Binding EditarClienteCommand}"
                                        MinWidth="120"
                                        Height="40"
                                        Padding="16,0"
                                        FontSize="12"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                                <Button Content="✕"
                                        FontSize="16"
                                        Width="36"
                                        Height="36"
                                        Background="Transparent"
                                        Foreground="#9ca3af"
                                        BorderThickness="0"
                                        CornerRadius="18"
                                        Command="{Binding CerrarFichaCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Contenido scrollable -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="28,24,40,24"
                                  VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="24" Margin="0,0,0,40">
                            
                            <!-- Información del Cliente -->
                            <Border Background="#111827"
                                    CornerRadius="12"
                                    Padding="20">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="📋 Información del Cliente"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,8"/>
                                    
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre:" Opacity="0.7" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ClienteSeleccionado.NombreCompleto}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Teléfono:" Opacity="0.7" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClienteSeleccionado.Telefono}" Margin="0,0,0,8"/>
                                        
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:" Opacity="0.7" Margin="0,0,12,8"
                                                   IsVisible="{Binding ClienteSeleccionado.Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ClienteSeleccionado.Email}" Margin="0,0,0,8"
                                                   IsVisible="{Binding ClienteSeleccionado.Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="DNI:" Opacity="0.7" Margin="0,0,12,8"
                                                   IsVisible="{Binding ClienteSeleccionado.Dni, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ClienteSeleccionado.Dni}" Margin="0,0,0,8"
                                                   IsVisible="{Binding ClienteSeleccionado.Dni, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Fecha Nacimiento:" Opacity="0.7" Margin="0,0,12,8"
                                                   IsVisible="{Binding ClienteSeleccionado.FechaNacimiento, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ClienteSeleccionado.FechaNacimientoConEdad}" Margin="0,0,0,8"
                                                   IsVisible="{Binding ClienteSeleccionado.FechaNacimiento, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Alergias:" Opacity="0.7" Margin="0,0,12,0"
                                                   IsVisible="{Binding ClienteSeleccionado.Alergias, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ClienteSeleccionado.Alergias}" TextWrapping="Wrap"
                                                   IsVisible="{Binding ClienteSeleccionado.Alergias, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Consentimientos -->
                            <Border Background="#111827"
                                    CornerRadius="12"
                                    Padding="20">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="📝 Consentimientos"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,8"/>
                                    
                                    <ItemsControl ItemsSource="{Binding ConsentimientosCliente}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:Consentimiento">
                                                <Border Background="#1a1a2e"
                                                        CornerRadius="8"
                                                        Padding="16"
                                                        Margin="0,0,0,12">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding NombreTipo}"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       Margin="0,0,0,4"/>
                                                            <TextBlock Text="{Binding FechaFirma, StringFormat='Firmado el {0:dd/MM/yyyy} a las {0:HH:mm}'}"
                                                                       FontSize="12"
                                                                       Opacity="0.7"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    Spacing="8"
                                                                    IsVisible="{Binding Firmado}">
                                                            <Button Content="📄"
                                                                    Classes="btn-secondary"
                                                                    Command="{Binding $parent[UserControl].DataContext.AbrirConsentimientoCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="Ver PDF"
                                                                    Width="36"
                                                                    Height="36"
                                                                    Padding="0"
                                                                    FontSize="18"
                                                                    HorizontalContentAlignment="Center"
                                                                    VerticalContentAlignment="Center"/>
                                                            <Button Content="💾"
                                                                    Classes="btn-secondary"
                                                                    Command="{Binding $parent[UserControl].DataContext.ExportarConsentimientoCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="Exportar PDF"
                                                                    Width="36"
                                                                    Height="36"
                                                                    Padding="0"
                                                                    FontSize="18"
                                                                    HorizontalContentAlignment="Center"
                                                                    VerticalContentAlignment="Center"/>
                                                            <Button Content="📧"
                                                                    Classes="btn-secondary"
                                                                    Command="{Binding $parent[UserControl].DataContext.EnviarConsentimientoPorCorreoCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="Enviar por correo"
                                                                    Width="36"
                                                                    Height="36"
                                                                    Padding="0"
                                                                    FontSize="18"
                                                                    HorizontalContentAlignment="Center"
                                                                    VerticalContentAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <TextBlock Text="No hay consentimientos firmados"
                                               IsVisible="{Binding !ConsentimientosCliente.Count}"
                                               Opacity="0.5"
                                               FontStyle="Italic"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Trabajos -->
                            <StackPanel Spacing="12">
                                <TextBlock Text="🎨 Historial de Trabajos"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,8"/>
                                
                                <!-- Lista de trabajos (solo si hay alguno) -->
                                <Border Background="#111827"
                                        CornerRadius="12"
                                        Padding="20"
                                        IsVisible="{Binding TrabajosCliente.Count}">
                                    <ItemsControl ItemsSource="{Binding TrabajosCliente}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:Trabajo">
                                                <Border Background="#1a1a2e"
                                                        CornerRadius="8"
                                                        Padding="16"
                                                        Margin="0,0,0,12">
                                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding IconoTipo}"
                                                                   FontSize="24"
                                                                   Margin="0,0,16,0"
                                                                   VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Descripcion}"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       Margin="0,0,0,4"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="12" Opacity="0.7">
                                                                <TextBlock Text="{Binding ZonaCuerpo}"/>
                                                                <TextBlock Text="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy}'}"/>
                                                                <TextBlock Text="{Binding Precio, StringFormat='{}{0:F2} €'}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Tipo}"
                                                                   FontSize="12"
                                                                   Opacity="0.6"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                                
                                <!-- Mensaje cuando no hay trabajos -->
                                <TextBlock Text="No hay trabajos registrados"
                                           IsVisible="{Binding !TrabajosCliente.Count}"
                                           Opacity="0.5"
                                           FontStyle="Italic"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Border Grid.Row="2"
                            Background="#111827"
                            Padding="28,20"
                            CornerRadius="0,0,18,18">
                        <Button Content="Cerrar"
                                Classes="btn-secondary"
                                Command="{Binding CerrarFichaCommand}"
                                HorizontalAlignment="Right"
                                MinWidth="120"
                                Height="42"
                                Padding="12,0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- Modal de firma de consentimientos -->
        <views:ConsentimientoFirmaView DataContext="{Binding ConsentimientoFirmaVM}"/>
        
    </Grid>

</UserControl>

