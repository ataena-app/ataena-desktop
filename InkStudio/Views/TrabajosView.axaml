<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InkStudio.ViewModels"
             xmlns:models="using:InkStudio.Models"
             x:Class="InkStudio.Views.TrabajosView"
             x:DataType="vm:TrabajosViewModel"
             Loaded="OnLoaded">

    <UserControl.Styles>
        <!-- Tarjeta de trabajo -->
        <Style Selector="Border.trabajo-card">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="Border.trabajo-card:pointerover">
            <Setter Property="Background" Value="#2a2a3e"/>
        </Style>
        
        <!-- Formulario -->
        <Style Selector="Border.form-container">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25"/>
        </Style>
        
        <!-- Campo de formulario -->
        <Style Selector="TextBox.form-field">
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        
        <!-- Botón primario -->
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        
        <!-- Botón secundario -->
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="#3a3a4e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        
        <!-- Botón peligro -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="#f44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA 0: LISTA DE TRABAJOS                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*,Auto" Margin="30">
            
            <!-- Cabecera -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="💼 Trabajos" FontSize="28" FontWeight="Bold"/>
                <TextBlock Opacity="0.6" Margin="0,5,0,0">
                    <Run Text="Total: "/>
                    <Run Text="{Binding TotalTrabajos}"/>
                    <Run Text=" trabajos"/>
                </TextBlock>
            </StackPanel>
            
            <!-- Barra de búsqueda, filtro y acciones -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,20">
                <TextBox Grid.Column="0"
                         Text="{Binding TextoBusqueda}"
                         Watermark="🔍 Buscar por descripción, zona, estilo o cliente..."
                         Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Clientes}"
                          SelectedItem="{Binding ClienteFiltro}"
                          Width="200"
                          Margin="0,0,10,0"
                          PlaceholderText="Filtrar por cliente">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NombreCompleto}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2"
                        Content="Buscar"
                        Command="{Binding CargarTrabajosCommand}"
                        Margin="0,0,10,0"/>
                <Button Grid.Column="3"
                        Content="➕ Nuevo Trabajo"
                        Classes="btn-primary"
                        Command="{Binding NuevoTrabajoCommand}"/>
            </Grid>
            
            <!-- Lista de trabajos -->
            <ScrollViewer Grid.Row="2">
                <ItemsControl ItemsSource="{Binding Trabajos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Trabajo">
                            <Border Classes="trabajo-card"
                                    PointerPressed="OnTrabajoClick"
                                    Tag="{Binding}">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    
                                    <!-- Icono del tipo -->
                                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                        <TextBlock Text="{Binding IconoTipo}" 
                                                   FontSize="32" 
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Tipo}" 
                                                   FontSize="12" 
                                                   Opacity="0.6"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Descripcion}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="15" Opacity="0.7" Margin="0,5,0,0">
                                            <TextBlock>
                                                <Run Text="📍 "/>
                                                <Run Text="{Binding ZonaCuerpo, TargetNullValue='Sin zona'}"/>
                                            </TextBlock>
                                            <TextBlock IsVisible="{Binding Estilo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Run Text="🎨 "/>
                                                <Run Text="{Binding Estilo}"/>
                                            </TextBlock>
                                            <TextBlock IsVisible="{Binding Tamano, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Run Text="📏 "/>
                                                <Run Text="{Binding Tamano}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="15" Opacity="0.6" Margin="0,5,0,0">
                                            <TextBlock>
                                                <Run Text="👤 "/>
                                                <Run Text="{Binding Cliente.NombreCompleto}"/>
                                            </TextBlock>
                                            <TextBlock>
                                                <Run Text="📅 "/>
                                                <Run Text="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy}'}"/>
                                            </TextBlock>
                                            <TextBlock>
                                                <Run Text="⏱️ "/>
                                                <Run Text="{Binding DuracionMinutos}"/>
                                                <Run Text=" min"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Precio -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Precio, StringFormat='{}{0:C}'}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#4CAF50"/>
                                        <TextBlock IsVisible="{Binding Colores}"
                                                   Text="🎨 Color"
                                                   FontSize="11"
                                                   Opacity="0.7"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Mensaje de error -->
            <Border Grid.Row="3"
                    IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="#3d2a2a"
                    CornerRadius="6"
                    Padding="15"
                    Margin="0,10,0,0">
                <TextBlock Text="{Binding MensajeError}" Foreground="#ef5350"/>
            </Border>
            
        </Grid>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MODAL: FORMULARIO DE CREACIÓN/EDICIÓN DE TRABAJO                -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                IsVisible="{Binding MostrarFormulario}"
                Background="#B0000000"
                Padding="40">
            <!-- Modal centrado con glow suave -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="540"
                    MaxWidth="660"
                    MaxHeight="800"
                    Background="#020617"
                    CornerRadius="18"
                    BoxShadow="0 0 80 0 #50d946ef, 0 0 120 0 #40ec4899">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Cabecera del modal -->
                    <Border Grid.Row="0"
                            Background="#111827"
                            Padding="28,22"
                            CornerRadius="18,18,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TituloFormulario}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    FontSize="16"
                                    Width="36"
                                    Height="36"
                                    Background="Transparent"
                                    Foreground="#9ca3af"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Command="{Binding CancelarEdicionCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Contenido scrollable -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="28,24,40,24"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- Cliente -->
                            <TextBlock Text="Cliente *" Opacity="0.7" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding Clientes}"
                                      SelectedItem="{Binding ClienteSeleccionado}"
                                      MinWidth="260">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding NombreCompleto}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Telefono}"
                                                       FontSize="11"
                                                       Opacity="0.7"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Tipo -->
                            <TextBlock Text="Tipo *" Opacity="0.7" Margin="16,16,0,5"/>
                            <ComboBox SelectedItem="{Binding TipoTrabajo}"
                                      Height="40">
                                <ComboBox.Items>
                                    <x:Static Member="models:TipoTrabajo.Tatuaje"/>
                                    <x:Static Member="models:TipoTrabajo.Piercing"/>
                                </ComboBox.Items>
                            </ComboBox>

                            <!-- Descripción -->
                            <TextBlock Text="Descripción *" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Text="{Binding Descripcion}"
                                     Watermark="Descripción del trabajo..."
                                     Classes="form-field"/>

                            <!-- Zona del cuerpo -->
                            <TextBlock Text="Zona del cuerpo" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Text="{Binding ZonaCuerpo}"
                                     Watermark="Brazo, pierna, espalda..."
                                     Classes="form-field"/>

                            <!-- Estilo y Tamaño -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,8,0,0">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Estilo" Opacity="0.7" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Estilo}"
                                             Watermark="Realismo, Old School..."
                                             Classes="form-field"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Tamaño" Opacity="0.7" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Tamano}"
                                             Watermark="10x15cm"
                                             Classes="form-field"/>
                                </StackPanel>
                            </Grid>

                            <!-- Colores (solo para tatuajes) -->
                            <CheckBox Content="Tiene colores 🎨"
                                      IsChecked="{Binding Colores}"
                                      IsVisible="{Binding TipoTrabajo, Converter={StaticResource EqualConverter}, ConverterParameter=Tatuaje}"
                                      Margin="0,12,0,15"/>

                            <!-- Precio, Fecha y Duración -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Precio (€) *" Opacity="0.7" Margin="0,0,0,5"/>
                                    <NumericUpDown Value="{Binding Precio}"
                                                   Minimum="0"
                                                   Maximum="10000"
                                                   Increment="10"
                                                   Height="40"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Fecha *" Opacity="0.7" Margin="0,0,0,5"/>
                                    <DatePicker SelectedDate="{Binding Fecha}"
                                                Height="40"
                                                HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>

                            <!-- Duración -->
                            <TextBlock Text="Duración (minutos) *" Opacity="0.7" Margin="16,16,0,5"/>
                            <NumericUpDown Value="{Binding DuracionMinutos}"
                                           Minimum="1"
                                           Maximum="480"
                                           Increment="15"
                                           Height="40"/>

                            <!-- Notas -->
                            <TextBlock Text="Notas" Opacity="0.7" Margin="16,16,0,5"/>
                            <TextBox Text="{Binding Notas}"
                                     Watermark="Notas adicionales..."
                                     AcceptsReturn="True"
                                     Height="80"
                                     TextWrapping="Wrap"/>

                            <!-- Mensaje de error -->
                            <Border IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="#3d2a2a"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,16,0,8">
                                <TextBlock Text="{Binding MensajeError}" 
                                           Foreground="#ef5350"
                                           TextWrapping="Wrap"/>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer botones -->
                    <Border Grid.Row="2"
                            Background="#111827"
                            Padding="24,16"
                            CornerRadius="0,0,18,18">
                        <Grid ColumnDefinitions="Auto,*">
                            <Button Grid.Column="0"
                                    Content="🗑️ Eliminar trabajo"
                                    Classes="btn-danger"
                                    Command="{Binding EliminarTrabajoCommand}"
                                    IsVisible="{Binding EsEdicion}"
                                    MinWidth="150"
                                    Height="40"
                                    HorizontalAlignment="Left"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="10">
                                <Button Content="Cancelar"
                                        Classes="btn-secondary"
                                        Command="{Binding CancelarEdicionCommand}"
                                        MinWidth="120"
                                        Height="40"/>
                                <Button Content="💾 Guardar"
                                        Classes="btn-primary"
                                        Command="{Binding GuardarTrabajoCommand}"
                                        MinWidth="120"
                                        Height="40"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>
        
        <!-- Overlay de carga -->
        <Border Grid.ColumnSpan="2"
                IsVisible="{Binding Cargando}"
                Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Cargando..." Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        
    </Grid>

</UserControl>

