<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InkStudio.ViewModels"
             xmlns:models="using:InkStudio.Models"
             xmlns:views="using:InkStudio.Views"
             xmlns:converters="using:InkStudio.Converters"
             x:Class="InkStudio.Views.AgendaView"
             x:DataType="vm:AgendaViewModel"
             Loaded="OnLoaded">

    <UserControl.Styles>
        <!-- Tarjeta de cita -->
        <Style Selector="Border.cita-card">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="Border.cita-card:pointerover">
            <Setter Property="Background" Value="#2a2a3e"/>
        </Style>
        
        <!-- Formulario -->
        <Style Selector="Border.form-container">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25"/>
        </Style>
        
        <!-- Modal container con animación de opacidad -->
        <Style Selector="Border.modal-container">
            <Style.Animations>
                <Animation Duration="0:0:0.25" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        
        <!-- Los estilos de botones están definidos globalmente en App.axaml -->
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- CONTENIDO PRINCIPAL: LISTA DE CITAS/CALENDARIO                  -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Grid.RowSpan="5" RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="30">
            
            <!-- Cabecera -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="📅 Agenda" FontSize="28" FontWeight="Bold"/>
                <TextBlock Opacity="0.6" Margin="0,5,0,0">
                    <Run Text="Total: "/>
                    <Run Text="{Binding TotalCitas}"/>
                    <Run Text=" citas"/>
                </TextBlock>
            </StackPanel>
            
            <!-- Navegación de fechas y vista -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,15">
                <Button Grid.Column="0" Content="◀" Command="{Binding DiaAnteriorCommand}" Margin="0,0,10,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding FechaSeleccionada}" Margin="0,0,10,0"/>
                <Button Grid.Column="2" Content="▶" Command="{Binding DiaSiguienteCommand}" Margin="0,0,10,0"/>
                <Button Grid.Column="3" Content="Hoy" Command="{Binding IrAHoyCommand}" Margin="0,0,10,0"/>
                <Button Grid.Column="4" Content="➕ Nueva Cita" Classes="btn-primary" Command="{Binding NuevaCitaCommand}"/>
            </Grid>
            
            <!-- Selector de vista y filtros -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*,Auto" Margin="0,0,0,15">
                <Button Grid.Column="0"
                        Content="Día"
                        Command="{Binding CambiarVistaCommand}"
                        CommandParameter="Dia"
                        Margin="0,0,5,0"/>
                <Button Grid.Column="1"
                        Content="Semana"
                        Command="{Binding CambiarVistaCommand}"
                        CommandParameter="Semana"
                        Margin="0,0,5,0"/>
                <Button Grid.Column="2"
                        Content="Mes"
                        Command="{Binding CambiarVistaCommand}"
                        CommandParameter="Mes"
                        Margin="0,0,10,0"/>
                <TextBlock Grid.Column="3" 
                          Text="Filtro: Próximamente"
                          Opacity="0.6"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
                <Button Grid.Column="4" Content="🔄 Actualizar" Command="{Binding CargarCitasCommand}"/>
            </Grid>
            
            <!-- Contenido: nueva vista semanal + lista de día/mes -->
            <Panel Grid.Row="3">
                <!-- Vista semanal personalizada -->
                <Grid IsVisible="{Binding MostrarSemana}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cabecera de días -->
                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Background="Transparent"/>

                    <ItemsControl Grid.Row="0"
                                  Grid.Column="1"
                                  ItemsSource="{Binding DiasSemana}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10"
                                        Padding="10,6"
                                        Margin="2"
                                        Background="#111827">
                                    <TextBlock Text="{Binding Etiqueta}"
                                               HorizontalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Columna de horas -->
                    <ItemsControl Grid.Row="1"
                                  Grid.Column="0"
                                  ItemsSource="{Binding HorasSemana}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="32"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Etiqueta}"
                                               FontSize="11"
                                               Opacity="0.6"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,4,0"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Rejilla de días/horas con Grid fijo para posicionar citas -->
                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Background="#020617"
                            CornerRadius="12"
                            BorderBrush="#111827"
                            BorderThickness="1"
                            Margin="2,0,0,0">
                        <!-- Grid único con 28 filas (14 horas * 2 slots) y 7 columnas -->
                        <Grid ColumnDefinitions="*,*,*,*,*,*,*"
                              RowDefinitions="32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32,32">
                            
                            <!-- Líneas de la rejilla - Dibujadas directamente en cada fila del Grid -->
                            <!-- Líneas horizontales (una por cada fila) -->
                            <Border Grid.Row="0" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="1" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="2" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="3" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="4" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="5" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="6" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="7" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="8" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="9" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="10" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="11" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="12" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="13" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="14" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="15" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="16" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="17" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="18" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="19" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="20" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="21" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="22" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="23" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="24" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="25" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="26" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            <Border Grid.Row="27" Grid.ColumnSpan="7" BorderBrush="#1f2933" BorderThickness="0,0.5,0,0"/>
                            
                            <!-- Líneas verticales (una por cada columna) -->
                            <Border Grid.Column="1" Grid.RowSpan="28" BorderBrush="#1f2933" BorderThickness="1,0,0,0"/>
                            <Border Grid.Column="2" Grid.RowSpan="28" BorderBrush="#1f2933" BorderThickness="1,0,0,0"/>
                            <Border Grid.Column="3" Grid.RowSpan="28" BorderBrush="#1f2933" BorderThickness="1,0,0,0"/>
                            <Border Grid.Column="4" Grid.RowSpan="28" BorderBrush="#1f2933" BorderThickness="1,0,0,0"/>
                            <Border Grid.Column="5" Grid.RowSpan="28" BorderBrush="#1f2933" BorderThickness="1,0,0,0"/>
                            <Border Grid.Column="6" Grid.RowSpan="28" BorderBrush="#1f2933" BorderThickness="1,0,0,0"/>

                            <!-- Bloques de citas superpuestos usando Canvas directo -->
                            <Canvas Name="CanvasCitas"
                                    Grid.ColumnSpan="7"
                                    Grid.RowSpan="28"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    ZIndex="10"
                                    Loaded="OnCanvasCitasLoaded"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Lista de citas para vista Día/Mes -->
                <ScrollViewer IsVisible="{Binding MostrarLista}">
                    <ItemsControl ItemsSource="{Binding Citas}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Cita">
                                <Border Classes="cita-card"
                                        PointerPressed="OnCitaClick"
                                        Tag="{Binding}">
                                    <Grid ColumnDefinitions="Auto,*,Auto">

                                        <!-- Icono y hora -->
                                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                            <TextBlock Text="{Binding IconoTipo}" FontSize="32" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding HoraInicioFormateada}" 
                                                       FontSize="18" 
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding DuracionFormateada}" 
                                                       FontSize="12" 
                                                       Opacity="0.6"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Info de la cita -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Cliente.NombreCompleto}" 
                                                       FontSize="16" 
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TipoCita}" 
                                                       Opacity="0.7" 
                                                       Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding Descripcion}" 
                                                       Opacity="0.6" 
                                                       Margin="0,3,0,0"
                                                       TextWrapping="Wrap"
                                                       IsVisible="{Binding Descripcion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>

                                        <!-- Estado -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <Border Background="{Binding Estado, Converter={StaticResource EstadoCitaToColorConverter}}"
                                                    Padding="8,4"
                                                    CornerRadius="4">
                                                <TextBlock Text="{Binding Estado}" 
                                                           FontSize="12" 
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Panel>
            
            <!-- Mensaje de error -->
            <Border Grid.Row="4"
                    IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="#3d2a2a"
                    CornerRadius="6"
                    Padding="15"
                    Margin="0,10,0,0">
                <TextBlock Text="{Binding MensajeError}" Foreground="#ef5350"/>
            </Border>
            
        </Grid>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MODAL: FORMULARIO DE EDICIÓN/CREACIÓN DE CITAS                  -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Grid.RowSpan="5"
                IsVisible="{Binding MostrarFormulario}"
                Background="#E0000000"
                ZIndex="1000"
                Padding="40"
                PointerPressed="OnModalBackdropClick">

            <!-- Modal centrado con glow suave -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="520"
                    MaxWidth="620"
                    MaxHeight="820"
                    Background="#020617"
                    CornerRadius="18"
                    Classes="modal-container"
                    BoxShadow="0 0 80 0 #50d946ef, 0 0 120 0 #40ec4899">
                
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Header del modal con título y botón cerrar -->
                    <Border Grid.Row="0"
                            Background="#2a2a3e"
                            Padding="30,24"
                            CornerRadius="18,18,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TituloFormulario}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
                            <Border Grid.Column="1"
                                    Width="40"
                                    Height="40"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <Button Content="✕"
                                        FontSize="18"
                                        Width="40"
                                        Height="40"
                                        Background="Transparent"
                                        Foreground="#b0b0b0"
                                        BorderThickness="0"
                                        CornerRadius="20"
                                        Command="{Binding CancelarEdicionCommand}"
                                        Cursor="Hand"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Classes="btn-close">
                                </Button>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Contenido del formulario (scrollable) -->
                    <ScrollViewer Grid.Row="1"
                                   Padding="0,0,12,0"
                                   Margin="0"
                                   VerticalScrollBarVisibility="Auto"
                                   HorizontalScrollBarVisibility="Disabled">
                        <Border Padding="30,30,30,100"
                                Margin="0">
                            <StackPanel Spacing="20">
                            
                            <!-- Cliente -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Cliente *" 
                                           Opacity="0.8" 
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#d0d0d0"/>
                                <ComboBox ItemsSource="{Binding Clientes}"
                                          SelectedItem="{Binding ClienteSeleccionado}"
                                          MinWidth="260">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding NombreCompleto}" 
                                                           FontSize="14"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Telefono}"
                                                           FontSize="11"
                                                           Opacity="0.7"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            
                            <!-- Trabajo -->
                            <StackPanel Spacing="8" IsVisible="{Binding TieneClienteSeleccionado}">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0"
                                               Text="Trabajo *" 
                                               Opacity="0.8" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#d0d0d0"/>
                                    <Button Grid.Column="1"
                                            Content="➕ Nuevo Trabajo"
                                            Classes="btn-primary"
                                            FontSize="11"
                                            Padding="10,6"
                                            Height="28"
                                            Command="{Binding CrearTrabajoNuevoCommand}"/>
                                </Grid>
                                <ComboBox ItemsSource="{Binding TrabajosDelCliente}"
                                          SelectedItem="{Binding TrabajoSeleccionado}"
                                          Height="40">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="{Binding IconoTipo}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Descripcion, TargetNullValue='Sin descripción'}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding ZonaCuerpo, TargetNullValue='Sin zona'}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            
                            <!-- Indicador de consentimiento -->
                            <Border IsVisible="{Binding MensajeConsentimiento, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="{Binding ColorFondoConsentimiento}"
                                    CornerRadius="8"
                                    Padding="14,10"
                                    BorderThickness="0">
                                <TextBlock Text="{Binding MensajeConsentimiento}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                            
                            <!-- Fecha y hora en grid -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                                <StackPanel Grid.Column="0" Spacing="8">
                                    <TextBlock Text="Fecha *" 
                                               Opacity="0.8" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#d0d0d0"/>
                                    <DatePicker SelectedDate="{Binding FechaCita}"
                                                 Height="40"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Text="Hora inicio * (HH:mm)" 
                                               Opacity="0.8" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#d0d0d0"/>
                                    <TextBox Text="{Binding HoraInicioString}"
                                             Watermark="10:00"
                                             Height="40"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Hora fin y duración -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                                <StackPanel Grid.Column="0" Spacing="8">
                                    <TextBlock Text="Hora fin (HH:mm)" 
                                               Opacity="0.8" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#d0d0d0"/>
                                    <TextBox Text="{Binding HoraFinString}"
                                             Watermark="11:00"
                                             ToolTip.Tip="Edita la hora de fin para ajustar automáticamente la duración"
                                             Height="40"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Text="Duración (min) *" 
                                               Opacity="0.8" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#d0d0d0"/>
                                    <NumericUpDown Value="{Binding DuracionMinutos}"
                                                   Minimum="15"
                                                   Maximum="480"
                                                   Increment="15"
                                                   Height="40"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Tipo y Estado -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                                <StackPanel Grid.Column="0" Spacing="8">
                                    <TextBlock Text="Tipo *" 
                                               Opacity="0.8" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#d0d0d0"/>
                                    <ComboBox SelectedItem="{Binding TipoCita}"
                                              Height="40">
                                        <ComboBox.Items>
                                            <x:Static Member="models:TipoCita.Tatuaje"/>
                                            <x:Static Member="models:TipoCita.Piercing"/>
                                            <x:Static Member="models:TipoCita.Consulta"/>
                                            <x:Static Member="models:TipoCita.Retoque"/>
                                        </ComboBox.Items>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Text="Estado *" 
                                               Opacity="0.8" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#d0d0d0"/>
                                    <ComboBox SelectedItem="{Binding EstadoCita}"
                                              Height="40">
                                        <ComboBox.Items>
                                            <x:Static Member="models:EstadoCita.Pendiente"/>
                                            <x:Static Member="models:EstadoCita.Confirmada"/>
                                            <x:Static Member="models:EstadoCita.EnProceso"/>
                                            <x:Static Member="models:EstadoCita.Completada"/>
                                            <x:Static Member="models:EstadoCita.Cancelada"/>
                                            <x:Static Member="models:EstadoCita.NoShow"/>
                                        </ComboBox.Items>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Descripción -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Descripción" 
                                           Opacity="0.8" 
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#d0d0d0"/>
                                <TextBox Text="{Binding Descripcion}"
                                         Watermark="Descripción del trabajo..."
                                         AcceptsReturn="True"
                                         Height="75"
                                         TextWrapping="Wrap"
                                         Padding="12,10"
                                         Background="#2a2a3e"
                                         Foreground="White"
                                         BorderBrush="#3a3a4e"
                                         BorderThickness="1"/>
                            </StackPanel>
                            
                            <!-- Notas -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Notas" 
                                           Opacity="0.8" 
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#d0d0d0"/>
                                <TextBox Text="{Binding Notas}"
                                         Watermark="Notas adicionales..."
                                         AcceptsReturn="True"
                                         Height="85"
                                         TextWrapping="Wrap"
                                         Padding="12,10"
                                         Background="#2a2a3e"
                                         Foreground="White"
                                         BorderBrush="#3a3a4e"
                                         BorderThickness="1"/>
                            </StackPanel>
                            
                            <!-- Mensaje de error -->
                            <Border IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="#3d2a2a"
                                    CornerRadius="10"
                                    Padding="16"
                                    BorderThickness="1"
                                    BorderBrush="#5d3a3a"
                                    Margin="0,5,0,20">
                                <TextBlock Text="{Binding MensajeError}" 
                                           Foreground="#ef5350"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           FontWeight="Medium"/>
                            </Border>
                            
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                    
                    <!-- Footer fijo con botones -->
                    <Border Grid.Row="2"
                            Background="#252530"
                            CornerRadius="0,0,18,18"
                            BorderThickness="0,1,0,0"
                            BorderBrush="#3a3a4e"
                            Padding="30,20">
                        <Grid ColumnDefinitions="*,Auto">
                            <!-- Botón eliminar (solo en edición, a la izquierda) -->
                            <Button Grid.Column="0"
                                    Content="🗑️ Eliminar cita"
                                    Classes="btn-danger"
                                    Command="{Binding EliminarCitaCommand}"
                                    IsVisible="{Binding EsEdicion}"
                                    HorizontalAlignment="Left"
                                    MinWidth="150"
                                    Height="44"/>
                            
                            <!-- Botones de acción (a la derecha) -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal" 
                                        Spacing="12">
                                <Button Content="Cancelar"
                                        Classes="btn-secondary"
                                        Command="{Binding CancelarEdicionCommand}"
                                        MinWidth="130"
                                        Height="44"
                                        FontSize="14"
                                        FontWeight="SemiBold"/>
                                <Button Content="💾 Guardar"
                                        Classes="btn-primary"
                                        Command="{Binding GuardarCitaCommand}"
                                        MinWidth="130"
                                        Height="44"
                                        FontSize="14"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>
        
        <!-- Overlay de carga -->
        <Border Grid.Row="0"
                Grid.RowSpan="5"
                IsVisible="{Binding Cargando}"
                Background="#80000000"
                ZIndex="999">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Cargando..." Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        
    </Grid>

</UserControl>
