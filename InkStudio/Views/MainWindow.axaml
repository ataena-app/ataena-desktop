<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:InkStudio.ViewModels"
        xmlns:views="using:InkStudio.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="InkStudio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="InkStudio CRM"
        Width="1200"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        WindowState="Maximized"
        Background="#12121a">

    <Window.Styles>
        <!-- Estilo para botones de navegación -->
        <Style Selector="Button.nav-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0a0"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="8,2"/>
        </Style>
        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2a2a3e"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="220,*">
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA 0: BARRA DE NAVEGACIÓN LATERAL                          -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#16161e">
            <DockPanel>
                
                <!-- Logo / Título -->
                <Border DockPanel.Dock="Top" Padding="20" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="🖋️ InkStudio" 
                                   FontSize="22" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="CRM" 
                                   FontSize="12" 
                                   Opacity="0.5"
                                   Margin="28,0,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Menú de navegación -->
                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    
                    <Button Classes="nav-btn" Command="{Binding IrADashboardCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="🏠" FontSize="18"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Classes="nav-btn" Command="{Binding IrAClientesCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="👥" FontSize="18"/>
                            <TextBlock Text="Clientes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Classes="nav-btn" Command="{Binding IrAAgendaCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="📅" FontSize="18"/>
                            <TextBlock Text="Agenda" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Classes="nav-btn" Command="{Binding IrATrabajosCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="💼" FontSize="18"/>
                            <TextBlock Text="Trabajos" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                </StackPanel>
                
                <!-- Separador -->
                <Border DockPanel.Dock="Top" 
                        Height="1" 
                        Background="#2a2a3e" 
                        Margin="20,20"/>
                
                <!-- Configuración y utilidades (abajo) -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,20">
                    <Button Classes="nav-btn" Command="{Binding IrAConsentimientosCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="📝" FontSize="18"/>
                            <TextBlock Text="Consentimientos" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav-btn" 
                            Command="{Binding IrAConfiguracionCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⚙️" FontSize="18"/>
                            <TextBlock Text="Configuración" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="nav-btn" 
                            Command="{Binding IrALogsCommand}"
                            ToolTip.Tip="Ver logs del sistema para diagnóstico">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="📋" FontSize="18"/>
                            <TextBlock Text="Logs" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Espaciador -->
                <Border/>
                
            </DockPanel>
        </Border>
        
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA 1: CONTENIDO PRINCIPAL (cambia según navegación)        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="#12121a">
            <Panel>
                <!-- Dashboard -->
                <views:DashboardView DataContext="{Binding DashboardVM}"
                                     IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).VistaActual, Converter={StaticResource EqualConverter}, ConverterParameter=Dashboard}"/>
                
                <!-- Clientes -->
                <views:ClientesView DataContext="{Binding ClientesVM}"
                                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).VistaActual, Converter={StaticResource EqualConverter}, ConverterParameter=Clientes}"/>
                
                <!-- Logs -->
                <views:LogsView DataContext="{Binding LogsVM}"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).VistaActual, Converter={StaticResource EqualConverter}, ConverterParameter=Logs}"/>
                
                <!-- Agenda -->
                <views:AgendaView DataContext="{Binding AgendaVM}"
                                  IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).VistaActual, Converter={StaticResource EqualConverter}, ConverterParameter=Agenda}"/>
                
                <!-- Trabajos -->
                <views:TrabajosView DataContext="{Binding TrabajosVM}"
                                     IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).VistaActual, Converter={StaticResource EqualConverter}, ConverterParameter=Trabajos}"/>

                <!-- Consentimientos -->
                <views:ConsentimientosView DataContext="{Binding ConsentimientosVM}"
                                           IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).VistaActual, Converter={StaticResource EqualConverter}, ConverterParameter=Consentimientos}"/>
                
                <!-- Placeholder para vistas no implementadas -->
                
                <StackPanel IsVisible="{Binding VistaActual, Converter={StaticResource EqualConverter}, ConverterParameter=Configuracion}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="⚙️" FontSize="64" HorizontalAlignment="Center"/>
                    <TextBlock Text="Configuración" FontSize="24" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock Text="Próximamente..." Opacity="0.6"/>
                </StackPanel>
            </Panel>
        </Border>
        
    </Grid>

</Window>
