# ─────────────────────────────────────────────────────────────
# Archivos compilados de .NET
# ─────────────────────────────────────────────────────────────
bin/
obj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
publish/

# ─────────────────────────────────────────────────────────────
# Visual Studio / Rider / VS Code
# ─────────────────────────────────────────────────────────────
.vs/
.vscode/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates
*.rsuser

# ─────────────────────────────────────────────────────────────
# NuGet
# ─────────────────────────────────────────────────────────────
*.nupkg
**/packages/*
!**/packages/build/

# ─────────────────────────────────────────────────────────────
# Base de datos SQLite (datos locales)
# ─────────────────────────────────────────────────────────────
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────────────────────
# Archivos de sistema operativo
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─────────────────────────────────────────────────────────────
# Logs y archivos temporales
# ─────────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
*.cache

# ─────────────────────────────────────────────────────────────
# Archivos de backup
# ─────────────────────────────────────────────────────────────
*.bak
*.backup
*~

# ─────────────────────────────────────────────────────────────
# Secretos y configuración local
# ─────────────────────────────────────────────────────────────
appsettings.local.json
secrets.json
*.pfx
*.key

